daerty5.variable = {};
daerty5.game = {};
daerty5.game.var = {};
// persistent autosave slots: { slotId: { enabled: bool, interval: minutes } }
daerty5.variable.auto_save_slots = {};
// runtime timers for autosave
daerty5._autoSaveTimers = {};
// next run timestamps (ms since epoch) per slot
daerty5._autoSaveNext = {};
// global autosave interval in minutes (used as default)
daerty5.variable.auto_save_interval = 5;

daerty5.getMaxSaveFiles = function () {
	try {
		if (DataManager && typeof DataManager.maxSavefiles === 'function') {
			return DataManager.maxSavefiles();
		}
	} catch (e) {}
	return 20;
};

daerty5.startAutoSave = function (savefileId) {
	try {
		var id = Number(savefileId);
		if (isNaN(id)) return;
		if (daerty5._autoSaveTimers[id]) return;
		// ensure slot object exists and mark enabled before saving so metadata is persisted into the slot
		if (!daerty5.variable.auto_save_slots[id]) daerty5.variable.auto_save_slots[id] = {};
		daerty5.variable.auto_save_slots[id].enabled = true;
		if (!daerty5.variable.auto_save_slots[id].interval) daerty5.variable.auto_save_slots[id].interval = daerty5.getAutoSaveInterval();
		// perform an immediate full save (this will also persist daerty metadata for the slot)
		DataManager.saveGame(id);
		// determine interval for this slot
		var slot = daerty5.variable.auto_save_slots[id] || {};
		var intervalMin = slot.interval || daerty5.getAutoSaveInterval();
		var timer = setInterval(function () {
			try {
				DataManager.saveGame(id);
				// schedule next run
				daerty5._autoSaveNext[id] = Date.now() + intervalMin * 60 * 1000;
			} catch (e) {
				console.error("AutoSave failed for slot", id, e);
			}
		}, intervalMin * 60 * 1000);
		daerty5._autoSaveTimers[id] = timer;
		// next run timestamp after the immediate save
		daerty5._autoSaveNext[id] = Date.now() + intervalMin * 60 * 1000;
		// ensure an interval value exists (already set above)
		// persist settings into the slot-specific daerty file
		try {
			daerty.save(id, daerty5);
		} catch (e) {}
	} catch (e) {
		console.error('startAutoSave error', e);
	}
};

daerty5.stopAutoSave = function (savefileId) {
	try {
		var id = Number(savefileId);
		if (isNaN(id)) return;
		if (daerty5._autoSaveTimers[id]) {
			clearInterval(daerty5._autoSaveTimers[id]);
			delete daerty5._autoSaveTimers[id];
		}
		if (daerty5.variable.auto_save_slots[id]) {
			daerty5.variable.auto_save_slots[id].enabled = false;
		}
		if (daerty5._autoSaveNext[id]) {
			delete daerty5._autoSaveNext[id];
		}
		try {
			daerty.save(id, daerty5);
		} catch (e) {}
	} catch (e) {
		console.error('stopAutoSave error', e);
	}
};

daerty5.toggleAutoSave = function (savefileId) {
	var id = Number(savefileId);
	if (isNaN(id)) return;
	var slot = daerty5.variable.auto_save_slots && daerty5.variable.auto_save_slots[id] ? daerty5.variable.auto_save_slots[id] : null;
	if (slot && slot.enabled) {
		daerty5.stopAutoSave(id);
		SoundManager.playSystemSound(2);
	} else {
		// ensure slot object exists and has interval
		if (!daerty5.variable.auto_save_slots[id]) daerty5.variable.auto_save_slots[id] = {};
		if (!daerty5.variable.auto_save_slots[id].interval) daerty5.variable.auto_save_slots[id].interval = daerty5.getAutoSaveInterval();
		daerty5.startAutoSave(id);
		SoundManager.playSystemSound(1);
	}
	daerty5.update_menu();
};

daerty5.isAutoSaveEnabled = function (savefileId) {
	var id = Number(savefileId);
	return !!(daerty5.variable.auto_save_slots && daerty5.variable.auto_save_slots[id] && daerty5.variable.auto_save_slots[id].enabled);
};

daerty5.getAutoSaveInterval = function () {
	var v = Number(daerty5.variable.auto_save_interval);
	if (isNaN(v) || v < 1) return 1;
	return Math.min(60, Math.max(1, Math.floor(v)));
};

daerty5.changeAutoSaveInterval = function (direction, event) {
	event && event.stopPropagation && event.stopPropagation();
	var inc = 1;
	if (direction === 'left') {
		daerty5.variable.auto_save_interval = Math.max(1, daerty5.getAutoSaveInterval() - inc);
		SoundManager.playSystemSound(2);
	} else {
		daerty5.variable.auto_save_interval = Math.min(60, daerty5.getAutoSaveInterval() + inc);
		SoundManager.playSystemSound(1);
	}
	// restart timers with new interval
	try {
		for (var sid in daerty5._autoSaveTimers) {
			if (daerty5._autoSaveTimers[sid]) {
				clearInterval(daerty5._autoSaveTimers[sid]);
				delete daerty5._autoSaveTimers[sid];
			}
		}
		for (var sid2 in daerty5.variable.auto_save_slots) {
			if (daerty5.variable.auto_save_slots[sid2]) {
				daerty5.startAutoSave(sid2);
			}
		}
	} catch (e) {
		console.error('Failed to restart autosave timers', e);
	}
	// persist autosave metadata into the per-slot daerty files (avoid writing autosave to default)
	try {
		for (var sid in daerty5.variable.auto_save_slots) {
			if (daerty5.variable.auto_save_slots.hasOwnProperty(sid)) {
				try {
					daerty.save(sid, daerty5);
				} catch (e) {}
			}
		}
	} catch (e) {}
	daerty5.update_menu();
};

daerty5.setAutoSaveIntervalFromPrompt = function () {
	try {
		var cur = daerty5.getAutoSaveInterval();
		var input = prompt("Set auto-save interval in minutes (1-60):", "" + cur);
		if (input === null) return;
		var v = parseInt(input);
		if (isNaN(v)) {
			SoundManager.playSystemSound(2);
			return;
		}
		v = Math.max(1, Math.min(60, v));
		daerty5.variable.auto_save_interval = v;
		// restart timers
		try {
			for (var sid in daerty5._autoSaveTimers) {
				if (daerty5._autoSaveTimers[sid]) {
					clearInterval(daerty5._autoSaveTimers[sid]);
					delete daerty5._autoSaveTimers[sid];
				}
			}
			for (var sid2 in daerty5.variable.auto_save_slots) {
				if (daerty5.variable.auto_save_slots[sid2]) {
					daerty5.startAutoSave(sid2);
				}
			}
		} catch (e) {
			console.error('Failed to restart autosave timers', e);
		}
		// persist autosave metadata into per-slot files (avoid writing autosave to default)
		try {
			for (var sid in daerty5.variable.auto_save_slots) {
				if (daerty5.variable.auto_save_slots.hasOwnProperty(sid)) {
					try {
						daerty.save(sid, daerty5);
					} catch (e) {}
				}
			}
		} catch (e) {}
		SoundManager.playSystemSound(1);
		daerty5.update_menu();
	} catch (e) {
		console.error('setAutoSaveIntervalFromPrompt error', e);
	}
};

daerty5.getSlotRemaining = function (savefileId) {
	var id = Number(savefileId);
	if (isNaN(id)) return null;
	var next = daerty5._autoSaveNext[id];
	if (!next) return null;
	var delta = Math.max(0, next - Date.now());
	var secs = Math.ceil(delta / 1000);
	if (secs < 0) secs = 0;
	return secs + "s";
};

daerty5.setPerSlotIntervalFromPrompt = function (savefileId) {
	try {
		var id = Number(savefileId);
		if (isNaN(id)) return;
		var cur = (daerty5.variable.auto_save_slots && daerty5.variable.auto_save_slots[id] && daerty5.variable.auto_save_slots[id].interval) ? daerty5.variable.auto_save_slots[id].interval : daerty5.getAutoSaveInterval();
		var input = prompt("Set auto-save interval (minutes, 1-60) for slot " + id + ":", "" + cur);
		if (input === null) return;
		var v = parseInt(input);
		if (isNaN(v)) {
			SoundManager.playSystemSound(2);
			return;
		}
		v = Math.max(1, Math.min(60, v));
		if (!daerty5.variable.auto_save_slots[id]) daerty5.variable.auto_save_slots[id] = {};
		daerty5.variable.auto_save_slots[id].interval = v;
		// if enabled, restart timer for this slot
		if (daerty5.variable.auto_save_slots[id].enabled) {
			try {
				if (daerty5._autoSaveTimers[id]) {
					clearInterval(daerty5._autoSaveTimers[id]);
					delete daerty5._autoSaveTimers[id];
				}
				daerty5.startAutoSave(id);
				// update next-run for display
				var intervalMin = daerty5.variable.auto_save_slots[id].interval || daerty5.getAutoSaveInterval();
				daerty5._autoSaveNext[id] = Date.now() + intervalMin * 60 * 1000;
			} catch (e) {
				console.error('Failed to restart autosave for slot', id, e);
			}
		}
		try {
			daerty.save(id, daerty5);
		} catch (e) {}
		SoundManager.playSystemSound(1);
		daerty5.update_menu();
	} catch (e) {
		console.error('setPerSlotIntervalFromPrompt error', e);
	}
};
