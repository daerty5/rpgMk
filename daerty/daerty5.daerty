/////////////////////////////////////////////////
// Menu item types
/////////////////////////////////////////////////

// insert row with buttons to scroll left and right for some context
//	appears as:
//	<-[key1] text [key2]->
//	scrolling is handled by scroll_left_handler and scroll_right_handler functions
//	text: string
//	key1,key2: key mapping
//	scroll_handler: single function that handles the left and right scroll arguments should be (direction, event)
daerty5.append_scroll_selector = function (text, key1, key2, scroll_handler) {
	var scroll_selector = daerty5.overlay.insertRow();
	scroll_selector.className = "scroll_selector_row";

	var scroll_left_button = scroll_selector.insertCell();
	scroll_left_button.className = "scroll_selector_buttons daerty5_cell";

	var scroll_text = scroll_selector.insertCell();
	scroll_text.className = "daerty5_cell";

	var scroll_right_button = scroll_selector.insertCell();
	scroll_right_button.className = "scroll_selector_buttons daerty5_cell";

	scroll_left_button.innerHTML = "←[" + key1 + "]";
	scroll_text.innerHTML = text;
	scroll_right_button.innerHTML = "[" + key2 + "]→";

	// scroll_left_button.addEventListener("touchstart", scroll_handler.bind(null, "left"));
	// scroll_right_button.addEventListener("touchstart",scroll_handler.bind(null,"right"));

	scroll_left_button.addEventListener("mousedown", scroll_handler.bind(null, "left"));
	scroll_right_button.addEventListener("mousedown", scroll_handler.bind(null, "right"));

	daerty5.key_listeners[key1] = scroll_handler.bind(null, "left");
	daerty5.key_listeners[key2] = scroll_handler.bind(null, "right");
};

// Insert a title row
//	A row in the menu that is just text
//	title: string
daerty5.append_title = function (title) {
	var title_row = daerty5.overlay.insertRow();
	var temp = title_row.insertCell();
	temp.className = "daerty5_cell_title";
	var title_text = title_row.insertCell();
	title_text.className = "daerty5_cell_title";
	temp = title_row.insertCell();
	temp.className = "daerty5_cell_title scroll_selector_buttons";
	temp.innerHTML = "[Hide]";
	temp.addEventListener("mousedown", function (event) {
		daerty5.daerty5_open = false;
		daerty5.overlay_box.remove();
		daerty5.overlay.remove();
		SoundManager.playSystemSound(2);
	});
	title_text.innerHTML = title;
};

// Insert a desciption row
//	A row in the menu that is just text (smaller than title)
//	text: string
daerty5.append_description = function (text) {
	var title_row = daerty5.overlay.insertRow();
	var temp = title_row.insertCell();
	temp.className = "daerty5_cell";
	var title_text = title_row.insertCell();
	title_text.className = "daerty5_cell";
	temp = title_row.insertCell();
	temp.className = "daerty5_cell";
	title_text.innerHTML = text;
};

// Append a cheat with some handler to activate
//	Appears as:
//	cheat text	status text[key]
//	cheat_text: string
//	status_text: string
//	key: key mapping
//	click_handler: function
daerty5.append_cheat = function (cheat_text, status_text, key, click_handler) {
	var cheat_row = daerty5.overlay.insertRow();

	var cheat_title = cheat_row.insertCell();
	cheat_title.className = "daerty5_cell";
	var temp = cheat_row.insertCell();
	temp.className = "daerty5_cell";
	var cheat = cheat_row.insertCell();
	cheat.className = "daerty5_buttons daerty5_cell";

	cheat_title.innerHTML = cheat_text;
	cheat.innerHTML = status_text + "[" + key + "]";
	// cheat.addEventListener("touchstart", click_handler, isSupportPassive ? { passive: false } : false);
	cheat.addEventListener("mousedown", click_handler);
	daerty5.key_listeners[key] = click_handler;
};

/////////////////////////////////////////////////////////////
// Various functions to settup each page of the cheat menu
/////////////////////////////////////////////////////////////

// Left and right scrollers for handling switching between menus
daerty5.scroll_cheat = function (direction, event) {
	event.stopPropagation();
	event.stopImmediatePropagation();
	if (direction == "left") {
		daerty5.variable.cheat_selected--;
		if (daerty5.variable.cheat_selected < 0) {
			daerty5.variable.cheat_selected = daerty5.menus.length - 1;
		}
	} else {
		daerty5.variable.cheat_selected++;
		if (daerty5.variable.cheat_selected > daerty5.menus.length - 1) {
			daerty5.variable.cheat_selected = 0;
		}
	}

	SoundManager.playSystemSound(0);
	daerty5.update_menu();
};

// Menu title with scroll options to go between menu, should be first
//	append on each menu
daerty5.append_cheat_title = function (cheat_name) {
	daerty5.append_title("Daerty5 (" + daerty5.version + ")");
	daerty5.append_scroll_selector(cheat_name, 2, 3, daerty5.scroll_cheat);
};

// Search UI state and helpers
daerty5.searchState = {
	type: "variables", // variables | switches | items
	query: "",
	page: 0,
	perPage: 50,
};

daerty5.search_perform = function () {
	var list = [];
	var t = daerty5.searchState.type;
	try {
		if (t === "variables") {
			if ($dataSystem && $dataSystem.variables) {
				for (var i = 1; i < $dataSystem.variables.length; i++) {
					list.push({ id: i, name: $dataSystem.variables[i] || "", value: typeof $gameVariables !== 'undefined' ? $gameVariables.value(i) : null });
				}
			}
		} else if (t === "switches") {
			if ($dataSystem && $dataSystem.switches) {
				for (var i2 = 1; i2 < $dataSystem.switches.length; i2++) {
					list.push({ id: i2, name: $dataSystem.switches[i2] || "", value: typeof $gameSwitches !== 'undefined' ? $gameSwitches.value(i2) : null });
				}
			}
		} else if (t === "items") {
			if ($dataItems) {
				for (var j = 1; j < $dataItems.length; j++) {
					var name = $dataItems[j] && $dataItems[j].name ? $dataItems[j].name : "";
					var partyCount = ($gameParty && $gameParty._items) ? ($gameParty._items[j] || 0) : 0;
					list.push({ id: j, name: name, value: partyCount });
				}
			}
		}
	} catch (e) {
		console.error('search_perform error', e);
	}

	var q = (daerty5.searchState.query || "").toString().toLowerCase().trim();
	// fuzzy scoring helper
	daerty5.fuzzyScore = daerty5.fuzzyScore || function (needle, haystack) {
		if (!needle || !haystack) return 0;
		var n = needle.toLowerCase();
		var h = haystack.toLowerCase();
		if (h.indexOf(n) !== -1) return 100 - h.indexOf(n);
		// subsequence match
		var i = 0, j = 0;
		while (i < n.length && j < h.length) {
			if (n[i] === h[j]) i++;
			j++;
		}
		if (i === n.length) return 50 - j / 100;
		return 0;
	};

	if (q.length > 0) {
		// compute score for each item and keep only matches
		var scored = [];
		for (var k = 0; k < list.length; k++) {
			var it = list[k];
			var hay = (it.id ? it.id.toString() + ' ' : '') + (it.name || '') + ' ' + (it.value === null || it.value === undefined ? '' : it.value.toString());
			var score = 0;
			// prefer id exact or prefix
			if (it.id && it.id.toString().indexOf(q) === 0) score = 120;
			score = Math.max(score, daerty5.fuzzyScore(q, hay));
			if (score > 0) scored.push({ score: score, it: it });
		}
		scored.sort(function (a, b) { return b.score - a.score; });
		list = scored.map(function (s) { return s.it; });
	} else {
		// default sort by id
		list.sort(function (a, b) { return a.id - b.id; });
	}

	return list;
};

// Bulk and persistence helpers
daerty5.search_bulkSet = function () {
	var sel = daerty5.searchState.selected || {};
	var ids = Object.keys(sel).map(function (s) { return parseInt(s); });
	if (!ids.length) { alert('No items selected'); return; }
	var input = prompt('Set value for selected (' + ids.length + '):','');
	if (input === null) return;
	var t = daerty5.searchState.type;
	ids.forEach(function (id) {
		try {
			if (t === 'switches') {
				var v = input.toLowerCase();
				var val = v === 'true' || v === '1' || v === 'on' ? true : (v === 'false' || v === '0' || v === 'off' ? false : Boolean(input));
				$gameSwitches.setValue(id, !!val);
			} else if (t === 'variables') {
				var nv = parseFloat(input);
				if (!isNaN(nv)) $gameVariables.setValue(id, nv); else $gameVariables.setValue(id, input);
			} else if (t === 'items') {
				var nv2 = parseInt(input);
				if (!isNaN(nv2)) $gameParty._items[id] = nv2;
			}
		} catch (e) {}
	});
	daerty5.update_menu();
};

daerty5.search_bulkFreeze = function () {
	var sel = daerty5.searchState.selected || {};
	var ids = Object.keys(sel).map(function (s) { return parseInt(s); });
	if (!ids.length) { alert('No items selected'); return; }
	if (!confirm('Freeze ' + ids.length + ' selected?')) return;
	var t = daerty5.searchState.type;
	ids.forEach(function (id) {
		try {
			if (t === 'variables') {
				var name = ($dataSystem && $dataSystem.variables && $dataSystem.variables[id]) || '';
				daerty5.freeze.var[id] = { name: name, value: $gameVariables.value(id) };
			} else if (t === 'switches') {
				var name2 = ($dataSystem && $dataSystem.switches && $dataSystem.switches[id]) || '';
				daerty5.freeze.switch[id] = { name: name2, value: $gameSwitches.value(id) };
			} else if (t === 'items') {
				var name3 = ($dataItems && $dataItems[id] && $dataItems[id].name) || '';
				daerty5.freeze.item[id] = { name: name3, value: ($gameParty && $gameParty._items) ? ($gameParty._items[id] || 0) : 0 };
			}
		} catch (e) {}
	});
	daerty5.update_menu();
};

daerty5.search_bulkClear = function () {
	var sel = daerty5.searchState.selected || {};
	var ids = Object.keys(sel).map(function (s) { return parseInt(s); });
	if (!ids.length) { alert('No items selected'); return; }
	if (!confirm('Clear ' + ids.length + ' selected?')) return;
	var t = daerty5.searchState.type;
	ids.forEach(function (id) {
		try {
			if (t === 'variables') $gameVariables.setValue(id, 0);
			else if (t === 'switches') $gameSwitches.setValue(id, false);
			else if (t === 'items') $gameParty._items[id] = 0;
		} catch (e) {}
	});
	daerty5.update_menu();
};

daerty5.search_persist = function () {
	var txt = prompt('Persist edits by saving to slot id (enter slot number):','');
	if (txt === null) return;
	var id = parseInt(txt);
	if (isNaN(id)) { alert('Invalid slot'); return; }
	try { DataManager.saveGame(id); } catch (e) { console.error('persist save error', e); alert('Save failed'); }
};

daerty5.search_setValue = function (id) {
	var t = daerty5.searchState.type;
	var cur = null;
	try {
		if (t === 'variables') cur = $gameVariables.value(id);
		else if (t === 'switches') cur = $gameSwitches.value(id);
		else if (t === 'items') cur = ($gameParty && $gameParty._items) ? ($gameParty._items[id] || 0) : 0;
	} catch (e) {
		cur = null;
	}
	var input = prompt('Set value for ' + t + ' id ' + id + ':', '' + cur);
	if (input === null) return;
	// try to coerce boolean for switches
	try {
		if (t === 'switches') {
			var v = input.toLowerCase();
			var val = v === 'true' || v === '1' || v === 'on' ? true : (v === 'false' || v === '0' || v === 'off' ? false : Boolean(input));
			$gameSwitches.setValue(id, !!val);
		} else if (t === 'variables') {
			var nv = parseFloat(input);
			if (!isNaN(nv)) $gameVariables.setValue(id, nv);
			else $gameVariables.setValue(id, input);
		} else if (t === 'items') {
			var nv2 = parseInt(input);
			if (!isNaN(nv2)) $gameParty._items[id] = nv2;
		}
	} catch (e) {
		console.error('search_setValue error', e);
	}
	daerty5.update_menu();
};

daerty5.search_changeType = function (newType) {
	daerty5.searchState.type = newType;
	daerty5.searchState.page = 0;
	daerty5.update_menu();
};

daerty5.search_jumpToId = function () {
	var txt = prompt('Jump to ID:','');
	if (txt === null) return;
	var id = parseInt(txt);
	if (isNaN(id)) return;
	// compute which page contains this id
	var list = daerty5.search_perform();
	var idx = list.findIndex(function(it){return it.id === id;});
	if (idx >= 0) {
		daerty5.searchState.page = Math.floor(idx / daerty5.searchState.perPage);
		daerty5.update_menu();
	} else {
		alert('ID not found in current type/filter');
	}
};

daerty5.search_prevPage = function () {
	if (daerty5.searchState.page > 0) daerty5.searchState.page--;
	daerty5.update_menu();
};

daerty5.search_nextPage = function (totalPages) {
	if (daerty5.searchState.page < totalPages - 1) daerty5.searchState.page++;
	daerty5.update_menu();
};

// Left and right scrollers for handling switching selected actors
daerty5.scroll_actor = function (direction, event) {
	event.stopPropagation();
	event.stopImmediatePropagation();
	if (direction == "left") {
		daerty5.variable.cheat_selected_actor--;
		if (daerty5.variable.cheat_selected_actor < 0) {
			daerty5.variable.cheat_selected_actor = $gameActors._data.length - 1;
		}
	} else {
		daerty5.variable.cheat_selected_actor++;
		if (daerty5.variable.cheat_selected_actor >= $gameActors._data.length) {
			daerty5.variable.cheat_selected_actor = 0;
		}
	}

	SoundManager.playSystemSound(0);
	daerty5.update_menu();
};

// Append actor selection to the menu
daerty5.append_actor_selection = function (key1, key2) {
	daerty5.append_title("Actor");

	var actor_name;

	if ($gameActors._data[daerty5.variable.cheat_selected_actor] && $gameActors._data[daerty5.variable.cheat_selected_actor]._name) {
		actor_name = "<font color='#0088ff'>" + $gameActors._data[daerty5.variable.cheat_selected_actor]._name + "</font>";
	} else {
		actor_name = "<font color='#ff0000'>NULL</font>";
	}

	daerty5.append_scroll_selector(actor_name, key1, key2, daerty5.scroll_actor);
};

// Hanler for the god_mode cheat
daerty5.god_mode_toggle = function (event) {
	if ($gameActors._data[daerty5.variable.cheat_selected_actor]) {
		if (!$gameActors._data[daerty5.variable.cheat_selected_actor].god_mode) {
			daerty5.god_mode($gameActors._data[daerty5.variable.cheat_selected_actor]);
			SoundManager.playSystemSound(1);
		} else {
			daerty5.god_mode_off($gameActors._data[daerty5.variable.cheat_selected_actor]);
			SoundManager.playSystemSound(2);
		}
		daerty5.update_menu();
	}
};

// Append the god_mode cheat to the menu
daerty5.append_godmode_status = function () {
	var status_text;
	if ($gameActors._data[daerty5.variable.cheat_selected_actor] && $gameActors._data[daerty5.variable.cheat_selected_actor].god_mode) {
		status_text = "<font color='#00ff00'>on</font>";
	} else {
		status_text = "<font color='#ff0000'>off</font>";
	}

	daerty5.append_cheat("Status:", status_text, 6, daerty5.god_mode_toggle);
};

// handler for the enemy hp to 0 cheat alive only
daerty5.enemy_hp_cheat_1 = function () {
	daerty5.set_enemy_hp(0, true);
	SoundManager.playSystemSound(1);
};

// handler for the enemy hp to 1 cheat alive only
daerty5.enemy_hp_cheat_2 = function () {
	daerty5.set_enemy_hp(1, true);
	SoundManager.playSystemSound(1);
};

// handler for the enemy hp to 0 cheat all
daerty5.enemy_hp_cheat_3 = function () {
	daerty5.set_enemy_hp(0, false);
	SoundManager.playSystemSound(1);
};

// handler for the enemy hp to 1 cheat all
daerty5.enemy_hp_cheat_4 = function () {
	daerty5.set_enemy_hp(1, false);
	SoundManager.playSystemSound(1);
};

// Append the enemy hp cheats to the menu
daerty5.append_enemy_cheats = function (key1, key2, key3, key4) {
	daerty5.append_title("Alive");
	daerty5.append_cheat("Enemy HP to 0", "Activate", key1, daerty5.enemy_hp_cheat_1);
	daerty5.append_cheat("Enemy HP to 1", "Activate", key2, daerty5.enemy_hp_cheat_2);
	daerty5.append_title("All");
	daerty5.append_cheat("Enemy HP to 0", "Activate", key3, daerty5.enemy_hp_cheat_3);
	daerty5.append_cheat("Enemy HP to 1", "Activate", key4, daerty5.enemy_hp_cheat_4);
};

// handler for the party hp cheat to 0 alive only
daerty5.party_hp_cheat_1 = function () {
	daerty5.set_party_hp(0, true);
	SoundManager.playSystemSound(1);
};

// handler for the party hp cheat to 1 alive only
daerty5.party_hp_cheat_2 = function () {
	daerty5.set_party_hp(1, true);
	SoundManager.playSystemSound(1);
};

// handler for the party hp cheat to full alive only
daerty5.party_hp_cheat_3 = function () {
	daerty5.recover_party_hp(true);
	SoundManager.playSystemSound(1);
};

// handler for the party hp cheat to 0 all
daerty5.party_hp_cheat_4 = function () {
