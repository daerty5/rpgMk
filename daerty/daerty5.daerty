// Auto Save slots menu
daerty5.menus.splice(0, 0, function () {
	daerty5.append_cheat_title("Auto Save Slots");
	// Interval setting (click to enter number directly)
	var interval_text = "<font color='#0088ff'>" + daerty5.getAutoSaveInterval() + " min</font>";
	daerty5.append_cheat("Interval:", interval_text, "", daerty5.setAutoSaveIntervalFromPrompt);

	var max = daerty5.getMaxSaveFiles();
	for (var i = 1; i <= max; i++) {
		var slot = daerty5.variable.auto_save_slots && daerty5.variable.auto_save_slots[i] ? daerty5.variable.auto_save_slots[i] : null;
		var enabled = slot && slot.enabled;
		var interval = slot && slot.interval ? slot.interval : daerty5.getAutoSaveInterval();
		var status_text = enabled ? "<font color='#00ff00'>On</font>" : "<font color='#ff0000'>Off</font>";
		daerty5.append_cheat("Slot " + i + " Enabled:", status_text, "", daerty5.toggleAutoSave.bind(null, i));
		daerty5.append_cheat("Slot " + i + " Interval:", "<font color='#0088ff'>" + interval + " min</font>", "", daerty5.setPerSlotIntervalFromPrompt.bind(null, i));
		// show next-run countdown if enabled
		if (enabled) {
			var remaining = daerty5.getSlotRemaining(i);
			if (!remaining) remaining = "--:--";
			daerty5.append_cheat("Slot " + i + " Next:", "<font color='#ffff00'>" + remaining + "</font>", "", function () {});
		}
	}
});

