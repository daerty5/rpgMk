daerty5.append_amount_selection = function (key1, key2) {
	daerty5.append_title("Amount");

	var current_amount = "<font color='#0088ff'>" + daerty5.variable.amounts[daerty5.variable.amount_index] + "</font>";
	daerty5.append_scroll_selector(current_amount, key1, key2, daerty5.scroll_amount);
};

