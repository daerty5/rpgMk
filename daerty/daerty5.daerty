// handler for saving positions
daerty5.save_position = function (pos_num, event) {
	daerty5.variable.saved_positions[pos_num].m = $gameMap.mapId();
	daerty5.variable.saved_positions[pos_num].x = $gamePlayer.x;
	daerty5.variable.saved_positions[pos_num].y = $gamePlayer.y;

	SoundManager.playSystemSound(1);
	daerty5.update_menu();
};

// handler for loading/recalling positions
daerty5.recall_position = function (pos_num, event) {
	if (daerty5.variable.saved_positions[pos_num].m != -1) {
		daerty5.teleport(daerty5.variable.saved_positions[pos_num].m, daerty5.variable.saved_positions[pos_num].x, daerty5.variable.saved_positions[pos_num].y);
		SoundManager.playSystemSound(1);
	} else {
		SoundManager.playSystemSound(2);
	}
	daerty5.update_menu();
};

// append the save/recall cheat to the menu
daerty5.append_save_recall = function (key1, key2, key3, key4, key5, key6) {
	daerty5.append_title("Current Position: ");

	if ($dataMapInfos[$gameMap.mapId()] && $dataMapInfos[$gameMap.mapId()].name) {
		var current_map = "" + $gameMap.mapId() + ": " + $dataMapInfos[$gameMap.mapId()].name;
		daerty5.append_description(current_map);

		var map_pos = "(" + $gamePlayer.x + ", " + $gamePlayer.y + ")";
		daerty5.append_description(map_pos);
	} else {
		daerty5.append_description("NULL");
	}

	var cur_key = 1;
	for (var i = 0; i < daerty5.variable.saved_positions.length; i++) {
		daerty5.append_title("Position " + (i + 1));

		var map_text;
		var pos_text;
		if (daerty5.variable.saved_positions[i].m != -1) {
			map_text = "" + daerty5.variable.saved_positions[i].m + ": ";
			if ($dataMapInfos[daerty5.variable.saved_positions[i].m].name) {
				map_text += $dataMapInfos[daerty5.variable.saved_positions[i].m].name;
			} else {
				map_text += "NULL";
			}
			pos_text = "(" + daerty5.variable.saved_positions[i].x + ", " + daerty5.variable.saved_positions[i].y + ")";
		} else {
			map_text = "NULL";
			pos_text = "NULL";
		}

		daerty5.append_cheat("Save:", map_text, "", daerty5.save_position.bind(null, i));
		cur_key++;

		daerty5.append_cheat("Recall:", pos_text, "", daerty5.recall_position.bind(null, i));
		cur_key++;
	}
};

// Left and right scrollers for handling switching between target teleport map
daerty5.scroll_map_teleport_selection = function (direction, event) {
	event.stopPropagation();
	event.stopImmediatePropagation();
	if (direction == "left") {
		daerty5.variable.teleport_location.m--;
		if (daerty5.variable.teleport_location.m < 1) {
			daerty5.variable.teleport_location.m = $dataMapInfos.length - 1;
		}
	} else {
		daerty5.variable.teleport_location.m++;
		if (daerty5.variable.teleport_location.m >= $dataMapInfos.length) {
			daerty5.variable.teleport_location.m = 1;
		}
	}

	SoundManager.playSystemSound(0);
	daerty5.update_menu();
};

// Left and right scrollers for handling switching between target teleport x coord
daerty5.scroll_x_teleport_selection = function (direction, event) {
	event.stopPropagation();
	event.stopImmediatePropagation();
	if (direction == "left") {
		daerty5.variable.teleport_location.x--;
		if (daerty5.variable.teleport_location.x < 0) {
			daerty5.variable.teleport_location.x = 255;
		}
	} else {
		daerty5.variable.teleport_location.x++;
		if (daerty5.variable.teleport_location.x > 255) {
			daerty5.variable.teleport_location.x = 0;
		}
	}

	SoundManager.playSystemSound(0);
	daerty5.update_menu();
};

// Left and right scrollers for handling switching between target teleport y coord
daerty5.scroll_y_teleport_selection = function (direction, event) {
	event.stopPropagation();
	event.stopImmediatePropagation();
	if (direction == "left") {
		daerty5.variable.teleport_location.y--;
		if (daerty5.variable.teleport_location.y < 0) {
			daerty5.variable.teleport_location.y = 255;
		}
	} else {
		daerty5.variable.teleport_location.y++;
		if (daerty5.variable.teleport_location.y > 255) {
			daerty5.variable.teleport_location.y = 0;
		}
	}

	SoundManager.playSystemSound(0);
	daerty5.update_menu();
};

// handler for teleporting to targed map and location
daerty5.teleport_current_location = function (event) {
	daerty5.teleport(daerty5.variable.teleport_location.m, daerty5.variable.teleport_location.x, daerty5.variable.teleport_location.y);
	SoundManager.playSystemSound(1);
	daerty5.update_menu();
};

// append the teleport cheat to the menu
daerty5.append_teleport = function (key1, key2, key3, key4, key5, key6, key7) {
	var current_map = "" + daerty5.variable.teleport_location.m + ": ";

	if ($dataMapInfos[daerty5.variable.teleport_location.m] && $dataMapInfos[daerty5.variable.teleport_location.m].name) {
		current_map += $dataMapInfos[daerty5.variable.teleport_location.m].name;
	} else {
		current_map += "NULL";
	}

	daerty5.append_scroll_selector(current_map, key1, key2, daerty5.scroll_map_teleport_selection);

	daerty5.append_scroll_selector("X: " + daerty5.variable.teleport_location.x, key3, key4, daerty5.scroll_x_teleport_selection);

	daerty5.append_scroll_selector("Y: " + daerty5.variable.teleport_location.y, key5, key6, daerty5.scroll_y_teleport_selection);

	daerty5.append_cheat("Teleport", "Activate", key7, daerty5.teleport_current_location);
};

daerty5.freeze_mode = function (mode) {
	if (mode == 1) {
		//freeze variable
		if ($gameVariables.value(daerty5.variable.variable_selection) != undefined) {
			var value = { name: $dataSystem.variables[daerty5.variable.variable_selection], value: $gameVariables.value(daerty5.variable.variable_selection) };
			daerty5.freeze.var[daerty5.variable.variable_selection] = value;
		}
	} else if (mode == 2) {
		//freeze stats
		if ($gameActors._data[daerty5.variable.cheat_selected_actor] && $gameActors._data[daerty5.variable.cheat_selected_actor]._paramPlus != undefined) {
			if (!daerty5.freeze.stat[daerty5.variable.cheat_selected_actor]) {
				daerty5.freeze.stat[daerty5.variable.cheat_selected_actor] = {};
			}
			var value = {
				name: $dataSystem.terms.params[daerty5.variable.stat_selection],
				value: $gameActors._data[daerty5.variable.cheat_selected_actor]._paramPlus[daerty5.variable.stat_selection],
			};
			daerty5.freeze.stat[daerty5.variable.cheat_selected_actor][daerty5.variable.stat_selection] = value;
		}
	} else if (mode == 4) {
		//freeze item
		if ($gameParty._items[daerty5.variable.item_selection] !== undefined) {
			var value = { name: $dataItems[daerty5.variable.item_selection].name, value: $gameParty._items[daerty5.variable.item_selection] };
			daerty5.freeze.item[daerty5.variable.item_selection] = value;
		} else {
			var value = { name: $dataItems[daerty5.variable.item_selection].name, value: 0 };
			daerty5.freeze.item[daerty5.variable.item_selection] = value;
		}
	} else if (mode == 5) {
		//freeze weapon
		if ($gameParty._weapons[daerty5.variable.weapon_selection] !== undefined) {
			var value = { name: $dataWeapons[daerty5.variable.weapon_selection].name, value: $gameParty._weapons[daerty5.variable.weapon_selection] };
			daerty5.freeze.weapon[daerty5.variable.weapon_selection] = value;
		} else {
			var value = { name: $dataWeapons[daerty5.variable.weapon_selection].name, value: 0 };
			daerty5.freeze.weapon[daerty5.variable.weapon_selection] = value;
		}
	} else if (mode == 6) {
		//freeze armor

		if ($gameParty._armors[daerty5.variable.armor_selection] !== undefined) {
			var value = { name: $dataArmors[daerty5.variable.weapon_selection].name, value: $gameParty._armors[daerty5.variable.armor_selection] };
			daerty5.freeze.armor[daerty5.variable.armor_selection] = value;
		} else {
			var value = { name: $dataArmors[daerty5.variable.weapon_selection].name, value: 0 };
			daerty5.freeze.armor[daerty5.variable.armor_selection] = value;
		}
	} else if (mode == 7) {
		var current_switch = "";
		var current_switch_value = "NULL";
		var switch_id = daerty5.variable.switch_selection;
		if ($dataSystem.switches[switch_id] && $dataSystem.switches[switch_id].length > 0) {
			current_switch = $dataSystem.switches[daerty5.variable.switch_selection];
		} else {
			current_switch = "NULL";
		}

		if ($gameSwitches.value(switch_id) != undefined) {
			current_switch_value = $gameSwitches.value(switch_id);
		}
		var value = { name: current_switch, value: current_switch_value };

		daerty5.freeze.switch[switch_id] = value;
	}
	daerty5.defaultsave();
	daerty5.update_menu();
};

daerty5.freeze_mode_off = function (mode) {
	if (mode == 1) {
		//freeze variable
		if (daerty5.freeze.var[daerty5.variable.variable_selection] !== undefined) {
			delete daerty5.freeze.var[daerty5.variable.variable_selection];
		}
	} else if (mode == 2) {
		//freeze stats
		if (daerty5.freeze.stat[daerty5.variable.cheat_selected_actor][daerty5.variable.stat_selection] !== undefined) {
			delete daerty5.freeze.stat[daerty5.variable.cheat_selected_actor][daerty5.variable.stat_selection];
		}
	} else if (mode == 4) {
		//freeze item
		if (daerty5.freeze.item[daerty5.variable.item_selection] !== undefined) {
			delete daerty5.freeze.item[daerty5.variable.item_selection];
		}
	} else if (mode == 5) {
		//freeze weapon
		if (daerty5.freeze.weapon[daerty5.variable.weapon_selection] !== undefined) {
			delete daerty5.freeze.weapon[daerty5.variable.weapon_selection];
		}
	} else if (mode == 6) {
		// freeze armor
		if (daerty5.freeze.armor[daerty5.variable.armor_selection] !== undefined) {
			delete daerty5.freeze.armor[daerty5.variable.armor_selection];
		}
	} else if (mode == 7) {
		if (daerty5.freeze.switch[daerty5.variable.switch_selection] !== undefined) {
			delete daerty5.freeze.switch[daerty5.variable.switch_selection];
		}
	}
};

daerty5.freeze_mode_toggle = function (direction, event) {
	//freeze_mode variable
	if (daerty5.freeze_mode_status == 1) {
		if (daerty5.freeze.var[daerty5.variable.variable_selection] === undefined) {
			daerty5.freeze_mode(1);
			SoundManager.playSystemSound(1);
		} else {
			daerty5.freeze_mode_off(1);
			SoundManager.playSystemSound(2);
		}
	} else if (daerty5.freeze_mode_status == 2) {
		//freeze_mode stat

		if ($gameActors._data[daerty5.variable.cheat_selected_actor] && $gameActors._data[daerty5.variable.cheat_selected_actor]._paramPlus) {
			if (daerty5.freeze.stat[daerty5.variable.cheat_selected_actor] && daerty5.freeze.stat[daerty5.variable.cheat_selected_actor][daerty5.variable.stat_selection] != undefined) {
				daerty5.freeze_mode_off(2);
				SoundManager.playSystemSound(2);
			} else {
				daerty5.freeze_mode(2);
				SoundManager.playSystemSound(1);
			}
		}
	} else if (daerty5.freeze_mode_status == 3) {
		//freeze_gold

		if (daerty5.freeze.gold.status) {
			daerty5.freeze.gold.status = false;

			SoundManager.playSystemSound(2);
		} else {
			daerty5.freeze.gold.amount = $gameParty._gold;
			daerty5.freeze.gold.status = true;

			SoundManager.playSystemSound(1);
		}
	} else if (daerty5.freeze_mode_status == 4) {
		//freeze item
		if (daerty5.freeze.item[daerty5.variable.item_selection] === undefined) {
			daerty5.freeze_mode(4);
			SoundManager.playSystemSound(1);
		} else {
			daerty5.freeze_mode_off(4);
			SoundManager.playSystemSound(2);
		}
	} else if (daerty5.freeze_mode_status == 5) {
		//freeze weapon

		if (daerty5.freeze.weapon[daerty5.variable.weapon_selection] === undefined) {
			daerty5.freeze_mode(5);
			SoundManager.playSystemSound(1);
		} else {
			daerty5.freeze_mode_off(5);
			SoundManager.playSystemSound(2);
		}
	} else if (daerty5.freeze_mode_status == 6) {
		//freeze armor
		if (daerty5.freeze.armor[daerty5.variable.armor_selection] === undefined) {
			daerty5.freeze_mode(6);
			SoundManager.playSystemSound(1);
		} else {
			daerty5.freeze_mode_off(6);
			SoundManager.playSystemSound(2);
		}
	} else if (daerty5.freeze_mode_status == 7) {
		//switch
		if (daerty5.freeze.switch[daerty5.variable.switch_selection] === undefined) {
			daerty5.freeze_mode(7);
			SoundManager.playSystemSound(1);
		} else {
			daerty5.freeze_mode_off(7);
			SoundManager.playSystemSound(2);
		}
	}
	daerty5.defaultsave();

	daerty5.update_menu();
};

daerty5.append_freeze_status = function (key, mode) {
	var status_text;
	if (mode == 1) {
		//stats variable
		if (daerty5.freeze.var[daerty5.variable.variable_selection] !== undefined) {
			status_text = "<font color='#00ff00'> On </font>";
		} else {
			status_text = "<font color='#ff0000'> Off </font>";
		}
		daerty5.freeze_mode_status = 1;
	} else if (mode == 2) {
		//status stats
		if (daerty5.freeze.stat[daerty5.variable.cheat_selected_actor] && daerty5.freeze.stat[daerty5.variable.cheat_selected_actor][daerty5.variable.stat_selection] !== undefined) {
			status_text = "<font color='#00ff00'> On </font>";
		} else {
			status_text = "<font color='#ff0000'> Off </font>";
		}
		daerty5.freeze_mode_status = 2;
	} else if (mode == 3) {
		//status gold
		if (daerty5.freeze.gold.status) {
			status_text = "<font color='#00ff00'> On </font>";
		} else {
			status_text = "<font color='#ff0000'> Off </font>";
		}
		daerty5.freeze_mode_status = 3;
	} else if (mode == 4) {
		//status item
		if (daerty5.freeze.item[daerty5.variable.item_selection] !== undefined) {
			status_text = "<font color='#00ff00'> On </font>";
		} else {
			status_text = "<font color='#ff0000'> Off </font>";
		}

		daerty5.freeze_mode_status = 4;
	} else if (mode == 5) {
		//status weapon
		if (daerty5.freeze.weapon[daerty5.variable.weapon_selection] !== undefined) {
			status_text = "<font color='#00ff00'> On </font>";
		} else {
			status_text = "<font color='#ff0000'> Off </font>";
		}

		daerty5.freeze_mode_status = 5;
	} else if (mode == 6) {
		//status armor
		if (daerty5.freeze.armor[daerty5.variable.armor_selection] !== undefined) {
			status_text = "<font color='#00ff00'> On </font>";
		} else {
			status_text = "<font color='#ff0000'> Off </font>";
		}

		daerty5.freeze_mode_status = 6;
	} else if (mode == 7) {
		if (daerty5.freeze.switch[daerty5.variable.switch_selection] !== undefined) {
			status_text = "<font color='#00ff00'> On </font>";
		} else {
			status_text = "<font color='#ff0000'> Off </font>";
		}
		daerty5.freeze_mode_status = 7;
	}

	daerty5.append_cheat("Freeze:", status_text, key, daerty5.freeze_mode_toggle);
};

//////////////////////////////////////////////////////////////////////////////////
// Final Functions for building each Menu and function list for updating the menu
//////////////////////////////////////////////////////////////////////////////////
// Check if already defined (allows game specific extensions to be loaded in any order)
if (typeof daerty5.menus == "undefined") {
	daerty5.menus = [];
}

// Extracted Panel renderer so other menus can reuse it
daerty5.render_panel = function (initialType) {
	daerty5.append_title('Daerty5 Panel');
	// main container row
	var row = daerty5.overlay.insertRow();
	var cell = row.insertCell();
	cell.colSpan = 3;
	var panel = document.createElement('div');
	panel.className = 'daerty-panel';

	// left column: search + list
	var left = document.createElement('div');
	left.className = 'daerty-left';
	var leftCtrl = document.createElement('div');
	leftCtrl.style.padding = '6px';
	leftCtrl.innerHTML = '<select id="panel_type"><option value="variables">Variables</option><option value="switches">Switches</option><option value="items">Items</option><option value="weapons">Weapons</option><option value="armors">Armors</option></select> <input id="panel_search" placeholder="search" style="width:140px;margin-left:6px"> <button id="panel_jump">Jump</button> <button id="panel_select_page">Select Page</button>';
	left.appendChild(leftCtrl);

	var listDiv = document.createElement('div');
	listDiv.style.overflowY = 'auto';
	listDiv.style.maxHeight = '360px';
	listDiv.id = 'panel_list';
	left.appendChild(listDiv);

	// right column: detail
	var right = document.createElement('div');
	right.className = 'daerty-right';
	right.id = 'panel_detail';
	right.innerHTML = '<div style="font-weight:bold;margin-bottom:6px">Detail</div><div id="panel_detail_content"></div>';

	panel.appendChild(left);
	panel.appendChild(right);
	cell.appendChild(panel);

	// bind controls
	setTimeout(function () {
		var tsel = document.getElementById('panel_type');
		var sin = document.getElementById('panel_search');
		var sbtn = document.getElementById('panel_jump');
		var sselect = document.getElementById('panel_select_page');
		if (tsel) {
			if (initialType) daerty5.search_changeType(initialType);
			tsel.value = daerty5.searchState.type;
			tsel.addEventListener('change', function (e) { daerty5.search_changeType(e.target.value); daerty5.update_menu(); });
		}
		if (sin) {
			sin.value = daerty5.searchState.query;
			sin.addEventListener('input', function (e) { daerty5.searchState.query = sin.value; daerty5.update_menu(); });
		}
		if (sbtn) sbtn.addEventListener('click', function () { daerty5.search_jumpToId(); });
		if (sselect) sselect.addEventListener('click', function () { document.getElementById('daerty_select_page') && document.getElementById('daerty_select_page').click(); });
	}, 1);

	// render list (simple page of first perPage matches)
	var results = daerty5.search_perform();
	var per = daerty5.searchState.perPage;
	var listRoot = document.getElementById('panel_list');
	if (listRoot) listRoot.innerHTML = '';
	for (var i = 0; i < Math.min(results.length, per); i++) {
		(function(it){
			var item = document.createElement('div');
			item.className = 'daerty-list-item';
			var cb = document.createElement('input'); cb.type='checkbox'; cb.dataset.id = it.id; cb.style.marginLeft='4px';
			cb.checked = !!(daerty5.searchState.selected && daerty5.searchState.selected[it.id]);
			cb.addEventListener('change', function(e){ if(!daerty5.searchState.selected) daerty5.searchState.selected = {}; if(e.target.checked) daerty5.searchState.selected[it.id]=true; else delete daerty5.searchState.selected[it.id]; });
			item.appendChild(cb);
			var idspan = document.createElement('span'); idspan.style.width='40px'; idspan.style.color='#00ffff'; idspan.innerText = it.id; item.appendChild(idspan);
			var namespan = document.createElement('span'); namespan.style.flex='1'; namespan.innerText = it.name || '(unnamed)'; item.appendChild(namespan);
			item.addEventListener('click', function(){ daerty5.searchState.current = it.id; daerty5.update_menu(); });
			if (listRoot) listRoot.appendChild(item);
		})(results[i]);
	}

	// render detail if selected
	var droot = document.getElementById('panel_detail_content');
	if (droot) {
		droot.innerHTML = '';
		var sel = daerty5.searchState.current;
		if (!sel && results.length) sel = results[0].id;
		if (sel) {
			var type = daerty5.searchState.type;
			var name = '';
			var value = '';
			try {
				if (type === 'variables') { name = ($dataSystem && $dataSystem.variables && $dataSystem.variables[sel]) || ''; value = $gameVariables.value(sel); }
				else if (type === 'switches') { name = ($dataSystem && $dataSystem.switches && $dataSystem.switches[sel]) || ''; value = $gameSwitches.value(sel); }
				else if (type === 'items') { name = ($dataItems && $dataItems[sel] && $dataItems[sel].name) || ''; value = ($gameParty._items && $gameParty._items[sel]) || 0; }
			} catch (e) {}
			var r1 = document.createElement('div'); r1.className='daerty-detail-row'; r1.innerHTML = '<b>ID:</b> ' + sel + ' &nbsp; <b>Name:</b> ' + name; droot.appendChild(r1);
			var r2 = document.createElement('div'); r2.className='daerty-detail-row'; r2.innerHTML = '<input id="panel_detail_input" style="width:120px" value="' + value + '"> <button id="panel_detail_save">Save</button> <button id="panel_detail_freeze">Freeze</button> <button id="panel_detail_persist">Persist</button>';
			droot.appendChild(r2);
			setTimeout(function(){ var inp = document.getElementById('panel_detail_input'); var s = document.getElementById('panel_detail_save'); var f = document.getElementById('panel_detail_freeze'); var p = document.getElementById('panel_detail_persist'); if(s) s.addEventListener('click', function(){ try { if(type==='variables'){ var nv = parseFloat(inp.value); if(!isNaN(nv)) $gameVariables.setValue(sel,nv); else $gameVariables.setValue(sel, inp.value);} else if(type==='switches'){ $gameSwitches.setValue(sel, !!(inp.value==='1' || inp.value.toLowerCase()==='true')); } else if(type==='items'){ var ni = parseInt(inp.value); if(!isNaN(ni)) $gameParty._items[sel]=ni; } daerty5.searchState.dirty = daerty5.searchState.dirty || {}; daerty5.searchState.dirty[sel]=true; daerty5.update_menu(); } catch(e){} }); if(f) f.addEventListener('click', function(){ if(!daerty5.freeze) daerty5.freeze = {}; if(type==='variables'){ daerty5.freeze.var = daerty5.freeze.var || {}; daerty5.freeze.var[sel] = { name:name, value:$gameVariables.value(sel) }; } else if(type==='switches'){ daerty5.freeze.switch = daerty5.freeze.switch || {}; daerty5.freeze.switch[sel] = { name:name, value:$gameSwitches.value(sel) }; } else if(type==='items'){ daerty5.freeze.item = daerty5.freeze.item || {}; daerty5.freeze.item[sel] = { name:name, value:($gameParty._items && $gameParty._items[sel])||0 }; } daerty5.update_menu(); }); if(p) p.addEventListener('click', function(){ var slot = prompt('Persist to slot id:','1'); if(slot!==null){ var sid = parseInt(slot); if(!isNaN(sid)) { try{ DataManager.saveGame(sid); daerty5.searchState.dirty = daerty5.searchState.dirty || {}; delete daerty5.searchState.dirty[sel]; daerty5.update_menu(); }catch(e){alert('Save failed');}} } }); },1);
		} else {
			droot.innerHTML = '<i>No selection</i>';
		}
	}
};

// Panel menu wrapper (keeps menus array entry)
daerty5.menus.splice(0, 0, function () {
	daerty5.render_panel();
});

// Search menu: searchable, paginated list for variables/switches/items
daerty5.menus.splice(0, 0, function () {
	daerty5.append_cheat_title("Search");

	// Controls row: type selector, search input, jump, virtualization toggle, bulk actions, persist
	var row = daerty5.overlay.insertRow();
	var cell1 = row.insertCell();
	cell1.className = "daerty5_cell_title";
	cell1.colSpan = 3;
	cell1.innerHTML = '<select id="daerty_search_type"><option value="variables">Variables</option><option value="switches">Switches</option><option value="items">Items</option></select> <input id="daerty_search_input" placeholder="search id/name/value" style="width:120px;margin-left:6px;"> <button id="daerty_search_jump">Jump</button> <button id="daerty_toggle_virtual">Virtual</button> <button id="daerty_bulk_set">Set Selected</button> <button id="daerty_bulk_freeze">Freeze Selected</button> <button id="daerty_bulk_clear">Clear Selected</button> <button id="daerty_persist">Persist Edits</button>';

	// bind controls (they are recreated each menu render)
	setTimeout(function () {
		var sel = document.getElementById('daerty_search_type');
		var inp = document.getElementById('daerty_search_input');
		var jb = document.getElementById('daerty_search_jump');
		var vb = document.getElementById('daerty_toggle_virtual');
		var bset = document.getElementById('daerty_bulk_set');
		var bfreeze = document.getElementById('daerty_bulk_freeze');
		var bclear = document.getElementById('daerty_bulk_clear');
		var bpersist = document.getElementById('daerty_persist');
		if (sel) {
			sel.value = daerty5.searchState.type;
			sel.addEventListener('change', function (e) { daerty5.search_changeType(e.target.value); });
		}
		if (inp) {
			inp.value = daerty5.searchState.query;
			inp.addEventListener('keydown', function (ev) {
				if (ev.key === '/') { ev.preventDefault(); }
			});
			var timer = null;
			inp.addEventListener('input', function (e) {
				if (timer) clearTimeout(timer);
				timer = setTimeout(function () {
					daerty5.searchState.query = inp.value;
					daerty5.update_menu();
				}, 200);
			});
			// focus shortcut: '/'
			if (!daerty5._searchFocusHandlerAdded) {
				daerty5._searchFocusHandlerAdded = true;
				window.addEventListener('keydown', function (ev) {
					if (ev.key === '/' && document.activeElement !== inp) {
						ev.preventDefault();
						try { inp.focus(); inp.select(); } catch (e) {}
					}
				});
			}
		}
		if (jb) jb.addEventListener('click', function () { daerty5.search_jumpToId(); });
		if (vb) vb.addEventListener('click', function () { daerty5.searchState.virtual = !daerty5.searchState.virtual; daerty5.update_menu(); });
		if (bset) bset.addEventListener('click', function () { daerty5.search_bulkSet(); });
		if (bfreeze) bfreeze.addEventListener('click', function () { daerty5.search_bulkFreeze(); });
		if (bclear) bclear.addEventListener('click', function () { daerty5.search_bulkClear(); });
		if (bpersist) bpersist.addEventListener('click', function () { daerty5.search_persist(); });
	}, 1);

	// Results
	var results = daerty5.search_perform();
	var total = results.length;
	var per = daerty5.searchState.perPage;
	var page = 0;

	// Info row
	var infoRow = daerty5.overlay.insertRow();
	var cA = infoRow.insertCell();
	cA.className = 'daerty5_cell';
	cA.innerHTML = 'Results: <font color="#00ff00">' + total + '</font>';
	var cB = infoRow.insertCell();
	cB.className = 'daerty5_cell';
	cB.innerHTML = '<font color="#00ffff">Virtual:</font> ' + (!!daerty5.searchState.virtual);
	var cC = infoRow.insertCell();
	cC.className = 'daerty5_cell daerty5_buttons';
	cC.innerHTML = '<font color="#ffffff">Selected:</font> <span id="daerty_selected_count">0</span>';

	// container row for results; supports virtualization when enabled
	var containerRow = daerty5.overlay.insertRow();
	var containerCell = containerRow.insertCell();
	containerCell.colSpan = 3;
	var containerDiv = document.createElement('div');
	containerDiv.style.width = '460px';
	containerDiv.style.height = '320px';
	containerDiv.style.overflowY = 'auto';
	containerDiv.style.background = 'rgba(0,0,0,0.2)';
	containerDiv.id = 'daerty_search_container';
	containerCell.appendChild(containerDiv);

	// build row elements helper with undo/redo, dirty indicator and keyboard navigation
	function renderRows(startIndex, count) {
		containerDiv.innerHTML = '';
		var endIndex = Math.min(results.length, startIndex + count);
		for (var i = startIndex; i < endIndex; i++) {
			(function (it) {
				var rowDiv = document.createElement('div');
				rowDiv.style.display = 'flex';
				rowDiv.style.alignItems = 'center';
				rowDiv.style.padding = '4px 6px';
				rowDiv.style.borderBottom = '1px solid #333';

				var chk = document.createElement('input');
				chk.type = 'checkbox';
				chk.style.marginRight = '8px';
				chk.dataset.id = it.id;
				chk.checked = !!(daerty5.searchState.selected && daerty5.searchState.selected[it.id]);
				chk.addEventListener('change', function (e) {
					if (!daerty5.searchState.selected) daerty5.searchState.selected = {};
					if (e.target.checked) daerty5.searchState.selected[it.id] = true; else delete daerty5.searchState.selected[it.id];
					var sc = document.getElementById('daerty_selected_count');
					if (sc) sc.innerText = Object.keys(daerty5.searchState.selected || {}).length;
				});
				rowDiv.appendChild(chk);

				var idSpan = document.createElement('span');
				idSpan.style.width = '48px';
				idSpan.style.color = '#00ffff';
				idSpan.innerText = it.id;
				rowDiv.appendChild(idSpan);

				var nameSpan = document.createElement('span');
				nameSpan.style.flex = '1';
				nameSpan.style.marginLeft = '8px';
				nameSpan.innerHTML = it.name && it.name.length ? it.name : '(unnamed)';
				rowDiv.appendChild(nameSpan);

				// small saved/dirty indicator
				var indicator = document.createElement('span');
				indicator.style.width = '12px';
				indicator.style.marginLeft = '6px';
				var dirtyMap = daerty5.searchState.dirty || {};
				if (dirtyMap[it.id]) {
					indicator.innerHTML = '<font color="#ff8800">●</font>'; // unsaved
				} else {
					indicator.innerHTML = '<font color="#00ff66">●</font>'; // clean
				}
				rowDiv.appendChild(indicator);

				// undo/redo containers
				var undoBtn = document.createElement('button');
				undoBtn.style.marginLeft = '6px';
				undoBtn.title = 'Undo (per-row)';
				undoBtn.innerText = '↶';
				undoBtn.addEventListener('click', function () {
					var uid = it.id;
					var ustack = (daerty5.searchState.undo && daerty5.searchState.undo[uid]) ? daerty5.searchState.undo[uid] : [];
					if (ustack && ustack.length) {
						var prev = ustack.pop();
						daerty5.searchState.redo = daerty5.searchState.redo || {};
						daerty5.searchState.redo[uid] = daerty5.searchState.redo[uid] || [];
						// push current
						try {
							var cur = (daerty5.searchState.type === 'variables') ? $gameVariables.value(uid) : (daerty5.searchState.type === 'switches' ? $gameSwitches.value(uid) : ($gameParty && $gameParty._items ? ($gameParty._items[uid] || 0) : 0));
						} catch (e) { cur = null; }
						daerty5.searchState.redo[uid].push(cur);
						// apply prev
						try {
							if (daerty5.searchState.type === 'variables') $gameVariables.setValue(uid, prev);
							else if (daerty5.searchState.type === 'switches') $gameSwitches.setValue(uid, !!prev);
							else if (daerty5.searchState.type === 'items') $gameParty._items[uid] = prev;
						} catch (e) {}
						// mark dirty/indicator
						daerty5.searchState.dirty = daerty5.searchState.dirty || {};
						daerty5.searchState.dirty[uid] = true;
						daerty5.update_menu();
					}
				});
				rowDiv.appendChild(undoBtn);

				var redoBtn = document.createElement('button');
				redoBtn.style.marginLeft = '2px';
				redoBtn.title = 'Redo (per-row)';
				redoBtn.innerText = '↷';
				redoBtn.addEventListener('click', function () {
					var uid = it.id;
					var rstack = (daerty5.searchState.redo && daerty5.searchState.redo[uid]) ? daerty5.searchState.redo[uid] : [];
					if (rstack && rstack.length) {
						var next = rstack.pop();
						daerty5.searchState.undo = daerty5.searchState.undo || {};
						daerty5.searchState.undo[uid] = daerty5.searchState.undo[uid] || [];
						try {
							var cur2 = (daerty5.searchState.type === 'variables') ? $gameVariables.value(uid) : (daerty5.searchState.type === 'switches' ? $gameSwitches.value(uid) : ($gameParty && $gameParty._items ? ($gameParty._items[uid] || 0) : 0));
						} catch (e) { cur2 = null; }
						daerty5.searchState.undo[uid].push(cur2);
						try {
							if (daerty5.searchState.type === 'variables') $gameVariables.setValue(uid, next);
							else if (daerty5.searchState.type === 'switches') $gameSwitches.setValue(uid, !!next);
							else if (daerty5.searchState.type === 'items') $gameParty._items[uid] = next;
						} catch (e) {}
						daerty5.searchState.dirty = daerty5.searchState.dirty || {};
						daerty5.searchState.dirty[uid] = true;
						daerty5.update_menu();
					}
				});
				rowDiv.appendChild(redoBtn);

				// value editor
				if (daerty5.searchState.type === 'switches') {
					var cb = document.createElement('input');
					cb.type = 'checkbox';
					cb.checked = !!it.value;
					cb.tabIndex = 0;
					cb.addEventListener('change', function () {
						try {
							// push to undo
							daerty5.searchState.undo = daerty5.searchState.undo || {};
							daerty5.searchState.undo[it.id] = daerty5.searchState.undo[it.id] || [];
							var prev = $gameSwitches.value(it.id);
							daerty5.searchState.undo[it.id].push(prev);
							daerty5.searchState.redo = daerty5.searchState.redo || {};
							daerty5.searchState.redo[it.id] = [];
							$gameSwitches.setValue(it.id, !!cb.checked);
							daerty5.searchState.dirty = daerty5.searchState.dirty || {};
							daerty5.searchState.dirty[it.id] = true;
						} catch (e) {}
						daerty5.update_menu();
					});
					rowDiv.appendChild(cb);
				} else {
					var inp = document.createElement('input');
					inp.type = 'text';
					inp.value = (it.value === null || it.value === undefined) ? '' : it.value;
					inp.style.width = '80px';
					inp.dataset.id = it.id;
					inp.tabIndex = 0;
					inp.addEventListener('keydown', function (ev) {
						if (ev.key === 'Enter') { ev.preventDefault(); inp.blur(); }
						else if (ev.key === 'Escape') { ev.preventDefault(); daerty5.update_menu(); }
						else if (ev.key === 'ArrowDown' || ev.key === 'ArrowUp') {
							// keyboard navigation
							ev.preventDefault();
							var focusables = containerDiv.querySelectorAll('input[type=text], input[type=checkbox]');
							var arr = Array.prototype.slice.call(focusables);
							var idx = arr.indexOf(document.activeElement);
							if (idx === -1) return;
							var nextIdx = (ev.key === 'ArrowDown') ? Math.min(arr.length - 1, idx + 1) : Math.max(0, idx - 1);
							var next = arr[nextIdx];
							if (next) { next.focus(); if (ev.shiftKey) { // range selection
									var last = daerty5.searchState.lastFocusedId;
									try {
										var newId = parseInt(next.dataset.id || next.parentElement.querySelector('input[type=checkbox]').dataset.id);
										if (!isNaN(last)) {
											var start = Math.min(last, newId), end = Math.max(last, newId);
											for (var z = start; z <= end; z++) daerty5.searchState.selected[z] = true;
										}
									} catch (e) {}
								}
							}
							daerty5.update_menu();
						}
					});
					inp.addEventListener('focus', function () { try { daerty5.searchState.lastFocusedId = it.id; } catch (e) {} });
					inp.addEventListener('blur', function (ev) {
						var v = ev.target.value;
						try {
							// push old value
							daerty5.searchState.undo = daerty5.searchState.undo || {};
							daerty5.searchState.undo[it.id] = daerty5.searchState.undo[it.id] || [];
							var prev = (daerty5.searchState.type === 'variables') ? $gameVariables.value(it.id) : ($gameParty && $gameParty._items ? ($gameParty._items[it.id] || 0) : 0);
							daerty5.searchState.undo[it.id].push(prev);
							daerty5.searchState.redo = daerty5.searchState.redo || {};
							daerty5.searchState.redo[it.id] = [];
							if (daerty5.searchState.type === 'variables') {
								var nv = parseFloat(v);
								if (!isNaN(nv)) $gameVariables.setValue(it.id, nv); else $gameVariables.setValue(it.id, v);
							} else if (daerty5.searchState.type === 'items') {
								var nv2 = parseInt(v);
								if (!isNaN(nv2)) $gameParty._items[it.id] = nv2;
							}
							daerty5.searchState.dirty = daerty5.searchState.dirty || {};
							daerty5.searchState.dirty[it.id] = true;
						} catch (e) { console.error('apply inline edit error', e); }
						daerty5.update_menu();
					});
					rowDiv.appendChild(inp);
				}

				containerDiv.appendChild(rowDiv);
			})(results[i]);
		}
	}

	// virtualization vs pagination
	if (daerty5.searchState.virtual && results.length > 0) {
		// pooled virtualization: spacer + fixed pool of nodes
		var rowHeight = 34; // px
		containerDiv.style.height = '320px';
		containerDiv.style.position = 'relative';
		// spacer to provide full scroll height
		var spacer = document.createElement('div');
		spacer.id = 'daerty_spacer';
		spacer.style.width = '1px';
		spacer.style.height = (results.length * rowHeight) + 'px';
		containerDiv.appendChild(spacer);
		// pool container
		var pool = document.createElement('div');
		pool.id = 'daerty_pool';
		pool.style.position = 'absolute';
		pool.style.top = '0';
		pool.style.left = '0';
		pool.style.right = '0';
		containerDiv.appendChild(pool);
		var visible = Math.ceil(320 / rowHeight) + 6;
		var poolSize = Math.min(visible, results.length);
		var nodes = [];
		for (var p = 0; p < poolSize; p++) {
			var nd = document.createElement('div');
			nd.style.position = 'absolute';
			nd.style.left = '0';
			nd.style.right = '0';
			nd.style.boxSizing = 'border-box';
			pool.appendChild(nd);
			nodes.push(nd);
		}

		function updatePool(startIndex) {
			startIndex = Math.max(0, Math.min(results.length - poolSize, startIndex));
			for (var k = 0; k < poolSize; k++) {
				var idx = startIndex + k;
				var nd = nodes[k];
				if (idx >= results.length) { nd.style.display = 'none'; continue; }
				nd.style.display = 'flex';
				nd.style.alignItems = 'center';
				nd.style.padding = '4px 6px';
				nd.style.borderBottom = '1px solid #333';
				nd.style.top = (idx * rowHeight) + 'px';
				nd.innerHTML = '';
				(function (it) {
					var chk = document.createElement('input'); chk.type = 'checkbox'; chk.style.marginRight = '8px'; chk.dataset.id = it.id;
					chk.checked = !!(daerty5.searchState.selected && daerty5.searchState.selected[it.id]);
					chk.addEventListener('change', function (e) { if (!daerty5.searchState.selected) daerty5.searchState.selected = {}; if (e.target.checked) daerty5.searchState.selected[it.id] = true; else delete daerty5.searchState.selected[it.id]; var sc = document.getElementById('daerty_selected_count'); if (sc) sc.innerText = Object.keys(daerty5.searchState.selected || {}).length; });
					nd.appendChild(chk);
					var idSpan = document.createElement('span'); idSpan.style.width = '48px'; idSpan.style.color = '#00ffff'; idSpan.innerText = it.id; nd.appendChild(idSpan);
					var nameSpan = document.createElement('span'); nameSpan.style.flex = '1'; nameSpan.style.marginLeft = '8px'; nameSpan.innerHTML = it.name && it.name.length ? it.name : '(unnamed)'; nd.appendChild(nameSpan);
					var indicator = document.createElement('span'); indicator.style.width = '12px'; indicator.style.marginLeft = '6px'; var dirtyMap = daerty5.searchState.dirty || {}; indicator.innerHTML = dirtyMap[it.id] ? '<font color="#ff8800">●</font>' : '<font color="#00ff66">●</font>'; nd.appendChild(indicator);
					nd.addEventListener('click', function () { daerty5.searchState.current = it.id; daerty5.update_menu(); });
				})(results[idx]);
			}
		}

		containerDiv.addEventListener('scroll', function () {
			var start = Math.floor(containerDiv.scrollTop / rowHeight);
			updatePool(start);
		});

		// initialize
		updatePool(0);
	} else {
		// simple pagination: render first page of perPage
		var perPage = daerty5.searchState.perPage;
		renderRows(0, perPage);
	}
	// select page helper
	var selectPageBtn = document.getElementById('daerty_select_page');
	if (selectPageBtn) {
		selectPageBtn.addEventListener('click', function () {
			daerty5.searchState.selected = daerty5.searchState.selected || {};
			if (daerty5.searchState.virtual) {
				// mark currently rendered rows
				var cbs = containerDiv.querySelectorAll('input[type=checkbox]');
				for (var ii = 0; ii < cbs.length; ii++) {
					var cbx = cbs[ii];
					var idv = parseInt(cbx.dataset.id);
					daerty5.searchState.selected[idv] = true;
				}
			} else {
				// select first page
				var perp = daerty5.searchState.perPage;
				for (var jj = 0; jj < Math.min(results.length, perp); jj++) {
					daerty5.searchState.selected[results[jj].id] = true;
				}
			}
			var sc2 = document.getElementById('daerty_selected_count'); if (sc2) sc2.innerText = Object.keys(daerty5.searchState.selected || {}).length;
			daerty5.update_menu();
		});
	}
	});

daerty5.menus.splice(0, 0, function () {
	daerty5.render_panel();
});

// Auto Save slots menu
daerty5.menus.splice(0, 0, function () {
	daerty5.render_panel();
});

// Cleaned-up menu entries using the panel where appropriate
daerty5.menus.splice(0, 0, function () {
	daerty5.render_panel();
});

daerty5.menus.splice(0, 0, function () {
	daerty5.render_panel('switches');
});

daerty5.menus.splice(0, 0, function () {
