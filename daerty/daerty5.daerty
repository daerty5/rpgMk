// keep menu in correct location
daerty5.position_menu = function (event) {
	//middle of screen
	if (daerty5.position == 0) {
		daerty5.overlay_box.style.left = "" + window.innerWidth / 2 + "px";
		daerty5.overlay_box.style.top = "" + window.innerHeight / 2 + "px";
		daerty5.overlay_box.style.right = "";
		daerty5.overlay_box.style.bottom = "";

		daerty5.overlay_box.style.marginLeft = "-110px";
		daerty5.overlay_box.style.marginTop = "-50px";

		daerty5.overlay.style.left = "" + window.innerWidth / 2 + "px";
		daerty5.overlay.style.top = "" + window.innerHeight / 2 + "px";
		daerty5.overlay.style.right = "";
		daerty5.overlay.style.bottom = "";

		daerty5.overlay.style.marginLeft = "-110px";
		daerty5.overlay.style.marginTop = "-50px";
	}
	// top left corner
	else if (daerty5.position == 1) {
		daerty5.overlay_box.style.left = "5px";
		daerty5.overlay_box.style.top = "5px";
		daerty5.overlay_box.style.right = "";
		daerty5.overlay_box.style.bottom = "";

		daerty5.overlay_box.style.marginLeft = "";
		daerty5.overlay_box.style.marginTop = "";

		daerty5.overlay.style.left = "5px";
		daerty5.overlay.style.top = "5px";
		daerty5.overlay.style.right = "";
		daerty5.overlay.style.bottom = "";

		daerty5.overlay.style.marginLeft = "";
		daerty5.overlay.style.marginTop = "";
	}
	// top right corner
	else if (daerty5.position == 2) {
		daerty5.overlay_box.style.left = "";
		daerty5.overlay_box.style.top = "5px";
		daerty5.overlay_box.style.right = "5px";
		daerty5.overlay_box.style.bottom = "";

		daerty5.overlay_box.style.marginLeft = "";
		daerty5.overlay_box.style.marginTop = "";

		daerty5.overlay.style.left = "";
		daerty5.overlay.style.top = "5px";
		daerty5.overlay.style.right = "-15px";
		daerty5.overlay.style.bottom = "";

		daerty5.overlay.style.marginLeft = "";
		daerty5.overlay.style.marginTop = "";
	}
	// bottom right corner
	else if (daerty5.position == 3) {
		daerty5.overlay_box.style.left = "";
		daerty5.overlay_box.style.top = "";
		daerty5.overlay_box.style.right = "5px";
		daerty5.overlay_box.style.bottom = "5px";

		daerty5.overlay_box.style.marginLeft = "";
		daerty5.overlay_box.style.marginTop = "";

		daerty5.overlay.style.left = "";
		daerty5.overlay.style.top = "";
		daerty5.overlay.style.right = "-15px";
		daerty5.overlay.style.bottom = "5px";

		daerty5.overlay.style.marginLeft = "";
		daerty5.overlay.style.marginTop = "";
	}
	// bottom left corner
	else if (daerty5.position == 4) {
		daerty5.overlay_box.style.left = "5px";
		daerty5.overlay_box.style.top = "";
		daerty5.overlay_box.style.right = "";
		daerty5.overlay_box.style.bottom = "5px";

		daerty5.overlay_box.style.marginLeft = "";
		daerty5.overlay_box.style.marginTop = "";

		daerty5.overlay.style.left = "5px";
		daerty5.overlay.style.top = "";
		daerty5.overlay.style.right = "";
		daerty5.overlay.style.bottom = "5px";

		daerty5.overlay.style.marginLeft = "";
		daerty5.overlay.style.marginTop = "";
	}

	// adjust background box size to match contents
	var height = 20;
	for (var i = 0; i < daerty5.overlay.children.length; i++) {
		height += daerty5.overlay.children[i].scrollHeight;
	}
	daerty5.overlay_box.style.height = "" + height + "px";
};

