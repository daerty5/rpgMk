	daerty5.append_title("Current Speed");
	daerty5.append_scroll_selector($gamePlayer._moveSpeed, key1, key2, daerty5.apply_speed_change);
	var status_text;
	if (!daerty5.variable.speed_unlocked) {
		status_text = "<font color='#00ff00'>false</font>";
	} else {
		status_text = "<font color='#ff0000'>true</font>";
	}
	daerty5.append_cheat("Speed Unlocked", status_text, key3, daerty5.apply_speed_lock_toggle);
};

