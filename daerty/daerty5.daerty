daerty5.style = function () {
	var style = `
.daerty_overlay_box {
	position: absolute;
	z-index: 1000;
	opacity: 0.95;
	color: #ffffff;
}
.daerty_overlay_box_inner {
	width: 300px;
	z-index: 1001;
	padding: 10px;
}
.scroll_selector_row {
	width: 100%;
	text-align: center;
}
.scroll_selector_buttons:hover {
	color: #ff0000;
	text-shadow: 0 0 5px #ff0000;
}
.daerty5_buttons:hover {
	color: #ff0000;
	text-shadow: 0 0 5px #ff0000;
}
.daerty5_cell {
	border-bottom: 1px solid #6f6f6f;
	max-width: 100px;
	width: 100px;
	font-weight: normal;
	font-size: 15px;
	padding-top: 5px;
	padding-bottom: 5px;
}
.daerty5_cell_title {
	max-width: 100px;
	width: 100px;
	font-weight: bold;
	font-size: 20px;
	padding-top: 8px;
	padding-bottom: 5px;
}
`;

	// Panel styles
	style += `
.daerty-panel {
	display: flex;
	gap: 12px;
	width: 720px;
	font-family: "Segoe UI", Roboto, Arial, sans-serif;
}
.daerty-left {
	width: 320px;
	max-height: 460px;
	overflow: hidden;
	background: linear-gradient(180deg, rgba(0,0,0,0.4), rgba(0,0,0,0.35));
	border: 1px solid #444;
	padding: 6px;
}
.daerty-right {
	flex: 1;
	max-height: 460px;
	overflow: auto;
	background: rgba(0,0,0,0.25);
	border: 1px solid #444;
	padding: 8px;
}
.daerty-list-item { padding:6px; border-bottom:1px solid #333; display:flex; align-items:center; gap:8px; height:34px; }
.daerty-list-item:hover { background: rgba(255,255,255,0.03); }
.daerty-detail-row { margin-bottom:8px; }
.daerty-panel header { font-weight:700; font-size:16px; color:#ffffff; margin-bottom:6px; }
`;
	var styleSheet = document.createElement("style");
	styleSheet.innerText = style;
	document.head.appendChild(styleSheet);
};

daerty5.setAutoSaveIntervalFromPrompt = function () {
	try {
		var cur = daerty5.getAutoSaveInterval();
		var input = prompt("Set auto-save interval in minutes (1-60):", "" + cur);
		if (input === null) return;
		var v = parseInt(input);
		if (isNaN(v)) {
			SoundManager.playSystemSound(2);
			return;
		}
		v = Math.max(1, Math.min(60, v));
		daerty5.variable.auto_save_interval = v;
		// restart timers
		try {
			for (var sid in daerty5._autoSaveTimers) {
				if (daerty5._autoSaveTimers[sid]) {
					clearInterval(daerty5._autoSaveTimers[sid]);
					delete daerty5._autoSaveTimers[sid];
				}
			}
			for (var sid2 in daerty5.variable.auto_save_slots) {
				if (daerty5.variable.auto_save_slots[sid2]) {
					daerty5.startAutoSave(sid2);
				}
			}
		} catch (e) {
			console.error('Failed to restart autosave timers', e);
		}
		// persist autosave metadata into per-slot files (avoid writing autosave to default)
		try {
			for (var sid in daerty5.variable.auto_save_slots) {
				if (daerty5.variable.auto_save_slots.hasOwnProperty(sid)) {
					try {
						daerty.save(sid, daerty5);
					} catch (e) {}
				}
			}
		} catch (e) {}
		SoundManager.playSystemSound(1);
		daerty5.update_menu();
	} catch (e) {
		console.error('setAutoSaveIntervalFromPrompt error', e);
	}
};

daerty5.getSlotRemaining = function (savefileId) {
	var id = Number(savefileId);
	if (isNaN(id)) return null;
	var next = daerty5._autoSaveNext[id];
	if (!next) return null;
	var delta = Math.max(0, next - Date.now());
	var secs = Math.ceil(delta / 1000);
	if (secs < 0) secs = 0;
	return secs + "s";
};

daerty5.setPerSlotIntervalFromPrompt = function (savefileId) {
	try {
		var id = Number(savefileId);
		if (isNaN(id)) return;
		var cur = (daerty5.variable.auto_save_slots && daerty5.variable.auto_save_slots[id] && daerty5.variable.auto_save_slots[id].interval) ? daerty5.variable.auto_save_slots[id].interval : daerty5.getAutoSaveInterval();
		var input = prompt("Set auto-save interval (minutes, 1-60) for slot " + id + ":", "" + cur);
		if (input === null) return;
		var v = parseInt(input);
		if (isNaN(v)) {
			SoundManager.playSystemSound(2);
			return;
		}
		v = Math.max(1, Math.min(60, v));
		if (!daerty5.variable.auto_save_slots[id]) daerty5.variable.auto_save_slots[id] = {};
		daerty5.variable.auto_save_slots[id].interval = v;
		// if enabled, restart timer for this slot
		if (daerty5.variable.auto_save_slots[id].enabled) {
			try {
				if (daerty5._autoSaveTimers[id]) {
					clearInterval(daerty5._autoSaveTimers[id]);
					delete daerty5._autoSaveTimers[id];
				}
				daerty5.startAutoSave(id);
				// update next-run for display
				var intervalMin = daerty5.variable.auto_save_slots[id].interval || daerty5.getAutoSaveInterval();
				daerty5._autoSaveNext[id] = Date.now() + intervalMin * 60 * 1000;
			} catch (e) {
				console.error('Failed to restart autosave for slot', id, e);
			}
		}
		try {
			daerty.save(id, daerty5);
		} catch (e) {}
		SoundManager.playSystemSound(1);
		daerty5.update_menu();
	} catch (e) {
		console.error('setPerSlotIntervalFromPrompt error', e);
	}
};
