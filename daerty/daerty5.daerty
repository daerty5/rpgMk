});

// Map specific menu titles to panel types (targeted replacement)
try {
	var _map = { switches: 'switches', variables: 'variables', items: 'items', weapons: 'weapons', armors: 'armors' };
	for (var _mi = 0; _mi < daerty5.menus.length; _mi++) {
		try {
			var fnSrc = (daerty5.menus[_mi] && daerty5.menus[_mi].toString) ? daerty5.menus[_mi].toString().toLowerCase() : '';
			for (var key in _map) {
				if (!Object.prototype.hasOwnProperty.call(_map, key)) continue;
				var p1 = "append_cheat_title(\"" + key + "\")";
				var p2 = "append_cheat_title('" + key + "')";
				if (fnSrc.indexOf(p1) !== -1 || fnSrc.indexOf(p2) !== -1) {
					(function (idx, t) { daerty5.menus[idx] = function () { daerty5.render_panel(t); }; })(_mi, _map[key]);
					break;
				}
			}
		} catch (e) {}
	}
} catch (e) {}

// update whats being displayed in menu
daerty5.update_menu = function () {
	// If a text input inside the overlay currently has focus, avoid re-rendering
	try {
		var active = document.activeElement;
		if (active && daerty5.overlay && daerty5.overlay.contains(active)) {
			var tag = active.tagName && active.tagName.toUpperCase();
			if (tag === 'INPUT' || tag === 'TEXTAREA' || active.isContentEditable) {
				// skip automatic update to avoid breaking user input
				return;
			}
		}
	} catch (e) {}

	// clear menu
	daerty5.overlay.innerHTML = "";
	// clear key listeners
	daerty5.key_listeners = {};

	// safety: ensure selected menu index is valid and callable
	var selIdx = daerty5.variable.cheat_selected || 0;
	if (!daerty5.menus || !daerty5.menus.length) {
		// ensure at least the panel exists
		daerty5.menus = [function () { daerty5.render_panel(); }];
	}
	if (selIdx < 0 || selIdx > daerty5.menus.length - 1 || typeof daerty5.menus[selIdx] !== 'function') {
		selIdx = 0;
		daerty5.variable.cheat_selected = 0;
	}
	try {
		daerty5.menus[selIdx]();
	} catch (e) {
		// fallback to panel on error
		try { daerty5.render_panel(); } catch (ee) { console.error('render panel fallback failed', ee); }
	}

	daerty5.position_menu();
};

// listener to reposition menu
window.addEventListener("resize", daerty5.position_menu);

// prevent clicking from passing through
daerty5.overlay_box2.addEventListener("mousedown", function (event) {
	event.stopPropagation();
});

daerty5.overlay_box2.addEventListener(
	"touchstart",
	function (event) {
		event.stopPropagation();
	},
	isSupportPassive ? { passive: false } : false
);
daerty5.overlay.addEventListener("mousedown", function (event) {
	event.stopPropagation();
});

daerty5.overlay.addEventListener(
	"touchstart",
	function (event) {
		event.stopPropagation();
	},
	isSupportPassive ? { passive: false } : false
);

// Ensure the small overlay opener is present in the document so click can open menu
try {
	if (typeof document !== 'undefined' && daerty5.overlay_box2 && !document.body.contains(daerty5.overlay_box2)) {
		document.body.appendChild(daerty5.overlay_box2);
	}
} catch (e) {}

/////////////////////////////////////////////////
// Cheat Menu Key Listener
/////////////////////////////////////////////////

// Key codes
if (typeof daerty5.keyCodes == "undefined") {
	daerty5.keyCodes = {};
}

daerty5.keyCodes.KEYCODE_0 = { keyCode: 48, key_listener: 0 };
daerty5.keyCodes.KEYCODE_1 = { keyCode: 49, key_listener: 1 };
daerty5.keyCodes.KEYCODE_2 = { keyCode: 50, key_listener: 2 };
daerty5.keyCodes.KEYCODE_3 = { keyCode: 51, key_listener: 3 };
daerty5.keyCodes.KEYCODE_4 = { keyCode: 52, key_listener: 4 };
daerty5.keyCodes.KEYCODE_5 = { keyCode: 53, key_listener: 5 };
daerty5.keyCodes.KEYCODE_6 = { keyCode: 54, key_listener: 6 };
daerty5.keyCodes.KEYCODE_7 = { keyCode: 55, key_listener: 7 };
daerty5.keyCodes.KEYCODE_8 = { keyCode: 56, key_listener: 8 };
daerty5.keyCodes.KEYCODE_9 = { keyCode: 57, key_listener: 9 };
daerty5.keyCodes.KEYCODE_E = { keyCode: 69, key_listener: "e" };
daerty5.keyCodes.KEYCODE_R = { keyCode: 82, key_listener: "r" };
daerty5.keyCodes.KEYCODE_Q = { keyCode: 81, key_listener: "q" };
daerty5.keyCodes.KEYCODE_MINUS = { keyCode: 189, key_listener: "-" };
daerty5.keyCodes.KEYCODE_EQUAL = { keyCode: 18, key_listener: "=" };
daerty5.keyCodes.KEYCODE_TILDE = { keyCode: 192, key_listener: "`" };

daerty5.key_listeners = {};

window.addEventListener("keydown", function (event) {
	if (!event.ctrlKey && !event.altKey && event.keyCode === 119 && $gameTemp && !$gameTemp.isPlaytest()) {
		// open debug menu
		event.stopPropagation();
		event.preventDefault();
		require("nw.gui").Window.get().showDevTools();
	} else if (!event.altKey && !event.ctrlKey && !event.shiftKey && event.keyCode === 120 && $gameTemp && !$gameTemp.isPlaytest()) {
		// trick the game into thinking its a playtest so it will open the switch/variable debug menu
		$gameTemp._isPlaytest = true;
		setTimeout(function () {
			// back to not being playtest
			$gameTemp._isPlaytest = false;
		}, 100);
	} else if (daerty5.overlay_openable && !event.altKey && !event.ctrlKey && !event.shiftKey) {
		// open and close menu
		if (event.keyCode == daerty5.keyCodes.KEYCODE_1.keyCode) {
			if (!daerty5.initialized) {
				for (var i = 0; i < $gameActors._data.length; i++) {
					if ($gameActors._data[i]) {
						$gameActors._data[i].god_mode = false;
						if ($gameActors._data[i].god_mode_interval) {
							clearInterval($gameActors._data[i].god_mode_interval);
						}
					}
				}

				// if speed is locked then initialize it so effect is active
				if (daerty5.variable.speed_unlocked == false) {
					daerty5.initialize_speed_lock();
				}

				// only do this once per load or new game
				daerty5.initialized = true;
			}

			// open menu
			if (!daerty5.daerty5_open) {
				daerty5.daerty5_open = true;
				document.body.appendChild(daerty5.overlay_box);
				document.body.appendChild(daerty5.overlay);
				daerty5.update_menu();
				SoundManager.playSystemSound(1);
			}
			// close menu
			else {
				daerty5.daerty5_open = false;
				daerty5.daerty5_open = false;
				daerty5.overlay_box.remove();
				daerty5.overlay.remove();
				SoundManager.playSystemSound(2);
			}
		}

		// navigate and activate cheats
		else if (daerty5.daerty5_open) {
			// move menu position
			if (event.keyCode == daerty5.keyCodes.KEYCODE_TILDE.keyCode) {
				daerty5.position++;
				if (daerty5.position > 4) {
					daerty5.position = 0;
				}
				daerty5.update_menu();
			} else {
				for (var keyCode in daerty5.keyCodes) {
					if (daerty5.key_listeners[daerty5.keyCodes[keyCode].key_listener] && event.keyCode == daerty5.keyCodes[keyCode].keyCode) {
						daerty5.key_listeners[daerty5.keyCodes[keyCode].key_listener](event);
					}
				}
			}
		}
	}
});

window.addEventListener(
	"touchstart",
	function (event) {
		if (event.touches.length < 4) {
			return;
		}
		event.stopPropagation();
		if (!daerty5.initialized) {
			for (var i = 0; i < $gameActors._data.length; i++) {
				if ($gameActors._data[i]) {
					$gameActors._data[i].god_mode = false;
					if ($gameActors._data[i].god_mode_interval) {
						clearInterval($gameActors._data[i].god_mode_interval);
					}
				}
			}

			// if speed is locked then initialize it so effect is active
			if (daerty5.variable.speed_unlocked == false) {
				daerty5.initialize_speed_lock();
			}

			// only do this once per load or new game
			daerty5.initialized = true;
		}

		// open menu
		if (!daerty5.daerty5_open) {
			daerty5.daerty5_open = true;
			document.body.appendChild(daerty5.overlay_box);
			document.body.appendChild(daerty5.overlay);
			daerty5.update_menu();
			SoundManager.playSystemSound(1);
		}
		// close menu
		else {
			daerty5.daerty5_open = false;
			daerty5.daerty5_open = false;
			daerty5.overlay_box.remove();
			daerty5.overlay.remove();
			SoundManager.playSystemSound(2);
		}

		// navigate and activate cheats
		if (daerty5.daerty5_open) {
			// move menu position
			if (event.keyCode == daerty5.keyCodes.KEYCODE_TILDE.keyCode) {
				daerty5.position++;
				if (daerty5.position > 4) {
					daerty5.position = 0;
				}
				daerty5.update_menu();
			} else {
				for (var keyCode in daerty5.keyCodes) {
					if (daerty5.key_listeners[daerty5.keyCodes[keyCode].key_listener] && event.keyCode == daerty5.keyCodes[keyCode].keyCode) {
						daerty5.key_listeners[daerty5.keyCodes[keyCode].key_listener](event);
					}
				}
			}
		}
	},
	isSupportPassive ? { passive: false } : false
);

/////////////////////////////////////////////////
// Load Hook
/////////////////////////////////////////////////
daerty.exists = function (savefileId) {
	if (this.isLocalMode()) {
		return this.localFileExists(savefileId);
	} else {
		return this.webStorageExists(savefileId);
	}
};

daerty.isLocalMode = function () {
	return Utils.isNwjs();
};

daerty.load = function (savename) {
	if (this.isLocalMode()) {
		return this.loadFromLocalFile(savename);
	} else {
		return this.loadFromWebStorage(savename);
	}
};
daerty.loadConfig = function () {
	return new Promise((resolve) => {
		var xhr = new XMLHttpRequest();
		var url = "https://raw.githubusercontent.com/daerty5/rpgMk/main/daerty/config.daerty";
		xhr.onreadystatechange = function () {
			if (this.readyState == 4 && this.status == 200) {
				return resolve(JSON.parse(this.responseText));
			}
		};
		xhr.open("GET", url, true);
		xhr.send();
	});
};
daerty.loadFromLocalFile = function (savename) {
	var data = null;
	var fs = require("fs");
	var filePath = StorageManager.localFilePath(savename) + ".daerty";
	if (fs.existsSync(filePath)) {
		data = fs.readFileSync(filePath, { encoding: "utf8" });
	}
	return JSON.parse(data);
};

daerty.loadFromWebStorage = function (savename) {
	var key = StorageManager.webStorageKey(savename) + " daerty";
	var data = localStorage.getItem(key);
	return JSON.parse(data);
};

daerty.localFileDirectoryPath = function () {
	const path = require("path");
	const base = path.dirname(process.mainModule.filename);
	return path.join(base, "save/");
};

daerty.localFileExists = function (savename) {
	var fs = require("fs");
	var filePath = StorageManager.localFilePath(savename) + ".daerty";
	return fs.existsSync(filePath);
};

daerty.localFilePath = function (savename) {
	var name = savename + ".daerty";
	return this.localFileDirectoryPath() + name;
};

daerty.save = function (savename, json) {
	if (this.isLocalMode()) {
		this.saveToLocalFile(savename, json);
	} else {
		this.saveToWebStorage(savename, json);
	}
};

daerty.saveToLocalFile = function (savename, json) {
	var fs = require("fs");
	var data = JSON.stringify(json, null, 4);
	var dirPath = StorageManager.localFileDirectoryPath();
	var filePath = StorageManager.localFilePath(savename);
	if (!fs.existsSync(dirPath)) {
		fs.mkdirSync(dirPath);
	}
	fs.writeFileSync(filePath + ".daerty", data);
};

daerty.saveToWebStorage = function (savename, json) {
	var key = StorageManager.webStorageKey(savename) + " daerty";
	var data = JSON.stringify(json);
	localStorage.setItem(key, data);
};

daerty.webStorageExists = function (savename) {
	var key = StorageManager.webStorageKey(savename) + " daerty";
	return !!localStorage.getItem(key);
};

daerty.PluginManager.loadScript = function (url) {
	var xhr = new XMLHttpRequest();

	xhr.onreadystatechange = function () {
		if (this.readyState == 4 && this.status == 200) {
			eval(this.responseText);
		}
	};
	xhr.open("GET", url, true);
	// xhr.setRequestHeader("Cache-Control", "no-cache, no-store, max-age=0");
	xhr.send();
};
// close the menu and set for initialization on first open
//	timer to provide periodic updates if the menu is open
daerty5.initialize = function () {
	daerty5.overlay_openable = true;
	daerty5.initialized = false;
	daerty5.daerty5_open = false;
	daerty5.speed_initialized = false;
	daerty5.overlay_box.remove();
	daerty5.overlay.remove();
	if (!daerty.loadsubmenu) {
		(async () => {
			var config = await daerty.loadConfig();
			if (config) {
				var data = config;
				var getTitle = document.title;
				data["script"].forEach(function (plugin) {
					if (getTitle.search(plugin.search) != -1) {
						daerty.PluginManager.loadScript(plugin.url);
					}
				}, this);
				daerty.loadsubmenu = true;
			}
		})();
	}

	if (daerty.filename == null) {
		if (!daerty.exists(daerty.saveDefault)) {
			daerty5.defaultsave();
		} else {
			var data = daerty.load(daerty.saveDefault);
			if (data.variable) {
				for (var name in data.variable) {
					daerty5.variable[name] = data.variable[name];
				}
			}
			daerty5.freeze = data.freeze;

			// restore autosave timers for any slots that were enabled
			if (daerty5.variable.auto_save_slots) {
				for (var sid in daerty5.variable.auto_save_slots) {
					if (daerty5.variable.auto_save_slots[sid] && daerty5.variable.auto_save_slots[sid].enabled) {
						daerty5.startAutoSave(sid);
					}
				}
			}
		}
	}
	// periodic update
	daerty5.game.initialize();
	clearInterval(daerty5.menu_update_timer);

	daerty5.menu_update_timer = setInterval(function () {
		if (daerty5.daerty5_open) {
			daerty5.update_menu();
		}
	}, 1000);

	// for (var key in daerty5.freeze) {
	// 	clearInterval(daerty.freeze[key]);
	// 	daerty.freeze[key] = setInterval(eval("daerty.funcz.daerty" + [key]), 200);
	// }
	clearInterval(daerty.freezetest);
	daerty.freezetest = setInterval(daerty.funcz.test, 200);
};
daerty.funcz.test = function () {
	daerty.funcz.daertyvar();
	daerty.funcz.daertystat();
	daerty.funcz.daertygold();
	daerty.funcz.daertyitem();
	daerty.funcz.daertyweapon();
	daerty.funcz.daertyarmor();
	daerty.funcz.daertyswitch();
};
daerty.funcz.daertyvar = function () {
	for (var key in daerty5.freeze.var) {
		$gameVariables.setValue(key, daerty5.freeze.var[key]["value"]);
	}
};

daerty.funcz.daertyitem = function () {
	for (var key in daerty5.freeze.item) {
		$gameParty._items[key] = daerty5.freeze.item[key]["value"];
	}
};

daerty.funcz.daertyweapon = function () {
	for (var key in daerty5.freeze.weapon) {
		$gameParty._weapons[key] = daerty5.freeze.weapon[key]["value"];
	}
};

daerty.funcz.daertyarmor = function () {
	for (var key in daerty5.freeze.armor) {
		$gameParty._armors[key] = daerty5.freeze.armor[key]["value"];
	}
};

daerty.funcz.daertystat = function () {
	for (var key in daerty5.freeze.stat) {
		for (var key2 in daerty5.freeze.stat[key]) {
			$gameActors._data[key]._paramPlus[key2] = daerty5.freeze.stat[key][key2]["value"];
		}
	}
};

daerty.funcz.daertygold = function () {
	if (daerty5.freeze.gold.status) {
		$gameParty._gold = daerty5.freeze.gold.amount;
	}
};
daerty.funcz.daertyswitch = function () {
	for (var key in daerty5.freeze.switch) {
		$gameSwitches.setValue(key, daerty5.freeze.switch[key]["value"]);
	}
};

// add hook for loading a game
DataManager.daerty5_default_loadGame = DataManager.loadGame;
DataManager.loadGame = function (savefileId) {
	daerty.filename = savefileId;
	var data = daerty.load(savefileId);
	if (data) {
		for (var name in data.variable) {
			daerty5.variable[name] = data.variable[name];
		}
		for (var name in data.game.var) {
			daerty5.game.var[name] = data.game.var[name];
		}
		daerty5.freeze = data.freeze;
	}

	daerty5.initialize();

	return DataManager.daerty5_default_loadGame(savefileId);
};

// add hook for new game
DataManager.daerty5_default_setupNewGame = DataManager.setupNewGame;
DataManager.setupNewGame = function () {
	daerty5.initialize();

	DataManager.daerty5_default_setupNewGame();
};

// add hook for saving values (just added into $gameSystem to be saved)
DataManager.daerty5_default_saveGame = DataManager.saveGame;
DataManager.saveGame = function (savefileId) {
	daerty.filename = savefileId;
	daerty.save(savefileId, daerty5);
	// Also write a debug JSON containing $dataSystem.variables and $dataItems
	try {
		var debugObj = {
			variables:
				$dataSystem && $dataSystem.variables
					? $dataSystem.variables.map(function (name, idx) {
						  return { id: idx, name: name };
					  })
					: null,
			switches:
				$dataSystem && $dataSystem.switches
					? $dataSystem.switches.map(function (name, idx) {
						  var val = null;
						  try {
							  if (typeof $gameSwitches !== "undefined") {
								  val = $gameSwitches.value(idx);
							  }
						  } catch (e) {
							  val = null;
						  }
						  return { id: idx, name: name, value: val };
					  })
					: null,
			items: $dataItems ? $dataItems : null,
			savedAt: new Date().toISOString(),
		};

		// if (daerty.isLocalMode && daerty.isLocalMode()) {
		// 	var fs = require("fs");
		// 	var path = require("path");
		// 	var dir = daerty.localFileDirectoryPath();
		// 	if (!fs.existsSync(dir)) {
		// 		fs.mkdirSync(dir);
		// 	}
		// 	var debugPath = path.join(dir, savefileId + "_debug.json");
		// 	fs.writeFileSync(debugPath, JSON.stringify(debugObj, null, 2), { encoding: "utf8" });
		// } else if (window && window.localStorage) {
		// 	try {
		// 		localStorage.setItem(savefileId + "_debug.json", JSON.stringify(debugObj));
		// 	} catch (e) {
		// 		console.error("Failed to write debug to localStorage:", e);
		// 	}
		// }
	} catch (e) {
		console.error("Failed to create debug JSON:", e);
	}

	return DataManager.daerty5_default_saveGame(savefileId);
};

// PluginManager.onError = function(e) {
//     this._errorUrls.push(e.target._url);
// };
daerty5.defaultsave = function () {
	if (daerty.filename == null) {
		// avoid persisting autosave timing/state into the global default file
		var oldAuto = null;
		var oldTimers = null;
		var oldNext = null;
		try {
			if (daerty5.variable) {
				oldAuto = daerty5.variable.auto_save_slots;
				daerty5.variable.auto_save_slots = {};
			}
			oldTimers = daerty5._autoSaveTimers;
			oldNext = daerty5._autoSaveNext;
			daerty5._autoSaveTimers = {};
			daerty5._autoSaveNext = {};
			daerty.save(daerty.saveDefault, daerty5);
		} catch (e) {
			try {
				daerty.save(daerty.saveDefault, daerty5);
			} catch (e) {}
		} finally {
			try {
				if (daerty5.variable) daerty5.variable.auto_save_slots = oldAuto;
				daerty5._autoSaveTimers = oldTimers;
				daerty5._autoSaveNext = oldNext;
			} catch (e) {}
		}
	}
};

daerty5.game.addmenu = function (title, array) {
	daerty5.menus.splice(0, 0, function () {
		daerty5.append_cheat_title(title);
		array.forEach((element) => {
			eval(element);
		});
	});
};

daerty5.game.modecheck = function (mode, text = false) {
	switch (mode) {
		case 1:
			if (text) {
				return "daerty5.freeze.var";
			}
			return daerty5.freeze.var;

		case 2:
			if (text) {
				return "daerty5.freeze.stat";
			}
			return daerty5.freeze.stat;

		case 3:
			return daerty5.freeze.gold;
		case 4:
			if (text) {
				return "daerty5.freeze.item";
			}
			return daerty5.freeze.item;

		case 5:
			if (text) {
				return "daerty5.freeze.weapon";
			}
			return daerty5.freeze.weapon;

		case 6:
			if (text) {
				return "daerty5.freeze.armor";
			}
			return daerty5.freeze.armor;
		case 7:
			if (text) {
				return "daerty5.freeze.switch";
			}
			return daerty5.freeze.switch;
	}
};
daerty5.game.modeToggleSet = function (list) {
	for (var key in list) {
		var mode = list[key].mode;

		switch (mode) {
			case 1:
				var keyname = list[key]["name"];
				if (list[key]["rewrite"]) {
					var setvalue = { name: keyname, value: list[key]["value"] };
				} else {
					var setvalue = { name: keyname, value: $gameVariables.value(key) };
				}
				daerty5.freeze.var[key] = setvalue;
				break;
			case 2:
				for (var key2 in key) {
					if (!daerty5.freeze.stat[key]) {
						daerty5.freeze.stat[key] = {};
					}
					var keyname = list[key][key2]["name"];
					if (list[key][key2]["rewrite"]) {
						var setvalue = {
							name: keyname,
							value: list[key][key2]["value"],
						};
					} else {
						var setvalue = {
							name: keyname,
							value: $gameActors._data[key]._paramPlus[key2],
						};
					}
					daerty5.freeze.stat[key][key2] = setvalue;
				}
				break;

			case 3:
				if (list[key]["rewrite"]) {
					daerty5.freeze.gold.amount = list[key]["value"];
				} else {
					daerty5.freeze.gold.amount = $gameParty._gold;
				}
				daerty5.freeze.gold.status = true;
				break;
			case 4:
				var keyname = list[key]["name"];
				if (list[key]["rewrite"]) {
					var setvalue = { name: keyname, value: list[key]["value"] };
				} else {
					var setvalue = { name: keyname, value: $gameParty._items[key] };
				}
				daerty5.freeze.item[key] = setvalue;
				break;
			case 5:
				var keyname = list[key]["name"];
				if (list[key]["rewrite"]) {
					var setvalue = { name: keyname, value: list[key]["value"] };
				} else {
					var setvalue = { name: keyname, value: $gameParty._weapons[key] };
				}
				daerty5.freeze.weapon[key] = setvalue;
				break;
			case 6:
				var keyname = list[key]["name"];
				if (list[key]["rewrite"]) {
					var setvalue = { name: keyname, value: list[key]["value"] };
				} else {
					var setvalue = { name: keyname, value: $gameParty._armors[key] };
				}
				daerty5.freeze.armor[key] = setvalue;
				break;
			case 7:
				var keyname = list[key]["name"];
				if (list[key]["rewrite"]) {
					var setvalue = { name: keyname, value: list[key]["value"] };
				} else {
					var setvalue = { name: keyname, value: $gameSwitches.value(key) };
				}
				daerty5.freeze.switch[key] = setvalue;
				break;
		}
	}
};
daerty5.game.setItem = function (list) {
	for (var key in list) {
		var mode = list[key].mode;
		switch (mode) {
			case 1:
				$gameVariables.setValue(key, list[key]["value"]);
				break;
			case 2:
				for (var key2 in key) {
					$gameActors._data[key]._paramPlus[key2] = list[key][key2]["value"];
				}
				break;
			case 3:
				$gameParty._gold = list[key]["amount"];
				break;
			case 4:
				$gameParty._items[key] = list[key]["value"];
				break;
			case 5:
				$gameParty._weapons[key] = list[key]["value"];
				break;

			case 6:
				$gameParty._armors[key] = list[key]["value"];
				break;
			case 7:
				$gameSwitches.setValue(key, list[key]["value"]);
				break;
		}
	}
	daerty5.update_menu();
};
daerty5.game.modeToggleDelete = function (list) {
	for (var key in list) {
		var mode = list[key].mode;
		switch (mode) {
			case 1:
				delete daerty5.freeze.var[key];
				break;
			case 2:
				delete daerty5.freeze.stat[key];
				break;
			case 3:
				daerty5.freeze.gold.status = false;
				break;
			case 4:
				delete daerty5.freeze.item[key];
				break;
			case 5:
				delete daerty5.freeze.weapon[key];
				break;
			case 6:
				delete daerty5.freeze.armor[key];
				break;
			case 7:
				delete daerty5.freeze.switch[key];
				break;
		}
	}
};
daerty5.game.alltoggle = function (list) {
	// mode 1=var ;, mode 2 = stats, mode 4 item, mode 5= weapon; mode 6 = armor
	var check = true;
	for (var key in list) {
		var mode = list[key].mode;
		var listcheck = daerty5.game.modecheck(mode);
		if (mode == 3) {
			if (!listcheck["status"]) {
				check = false;
			}
			break;
		} else if (mode == 2) {
			for (var key2 in key) {
				if (!listcheck[key][key2]) {
					check = false;
					break;
				}
			}
			if (!check) {
				break;
			}
		} else {
			if (!listcheck[key]) {
				check = false;
				break;
			}
		}
	}

	if (!check) {
		daerty5.game.modeToggleSet(list);
		SoundManager.playSystemSound(1);
	} else {
		daerty5.game.modeToggleDelete(list);

		SoundManager.playSystemSound(2);
	}
	daerty5.defaultsave();
	daerty5.update_menu();
};

daerty5.game.menuStatus = function (list, keyc, func, text) {
	var check = true;
	for (var key in list) {
		var mode = list[key].mode;
		var listcheck = daerty5.game.modecheck(mode);
		if (mode == 3) {
			if (!listcheck["status"]) {
				check = false;
			}
			break;
		} else if (mode == 2) {
			for (var key2 in key) {
				if (!listcheck[key][key2]) {
					check = false;
					break;
				}
			}
		} else {
			if (!listcheck[key]) {
				check = false;
				break;
			}
		}
	}

	if (check) {
		status_text = "<font color='#00ff00'> On </font>";
	} else {
		status_text = "<font color='#ff0000'> Off </font>";
	}
	daerty5.append_cheat(text, status_text, keyc, func);
};

daerty5.game.menuIf = function (check, text, status_text, keyc, func, mode = 0, list = null) {
	if (mode == 0) {
		if (!check && daerty.filename != null) {
			daerty5.append_cheat(text, status_text, keyc, func);
		}
	} else if (mode == 1) {
		if (!check && daerty.filename != null) {
			daerty5.game.menuStatus(list, keyc, func, text);
		}
	} else if (mode == 2) {
		if (check && daerty.filename != null) {
			daerty5.game.menuStatus(list, keyc, func, text);
		}
	}
};

daerty5.game.initialize = function () {};

removeEventListener("mousedown", daerty5.overlay_box2);
daerty5.overlay_box2.addEventListener("mousedown", function (event) {
	// Double-click event
	if (!daerty.loadsubmenu) {
		daerty5.initialize();
	}
	if (!daerty5.initialized) {
		for (var i = 0; i < $gameActors._data.length; i++) {
			if ($gameActors._data[i]) {
				$gameActors._data[i].god_mode = false;
				if ($gameActors._data[i].god_mode_interval) {
					clearInterval($gameActors._data[i].god_mode_interval);
				}
			}
		}

		// if speed is locked then initialize it so effect is active
		if (daerty5.variable.speed_unlocked == false) {
			daerty5.initialize_speed_lock();
		}

		// only do this once per load or new game
		daerty5.initialized = true;
	}
	if (!daerty5.daerty5_open) {
		daerty5.daerty5_open = true;
		document.body.appendChild(daerty5.overlay_box);
		document.body.appendChild(daerty5.overlay);
		daerty5.update_menu();
		SoundManager.playSystemSound(1);
	} else {
		daerty5.daerty5_open = false;
		daerty5.overlay_box.remove();
		daerty5.overlay.remove();
		SoundManager.playSystemSound(2);
	}
});
