// handler for the toggle no clip cheat
daerty5.toggle_no_clip_status = function (event) {
	$gamePlayer._through = !$gamePlayer._through;
	daerty5.update_menu();
	if ($gamePlayer._through) {
		SoundManager.playSystemSound(1);
	} else {
		SoundManager.playSystemSound(2);
	}
};

// appen the no clip cheat
daerty5.append_no_clip_status = function (key1) {
	var status_text;
	if ($gamePlayer._through) {
		status_text = "<font color='#00ff00'>on</font>";
	} else {
		status_text = "<font color='#ff0000'>off</font>";
	}

	daerty5.append_cheat("Status:", status_text, key1, daerty5.toggle_no_clip_status);
};

// Left and right scrollers for handling switching amount to modify numerical cheats
daerty5.scroll_amount = function (direction, event) {
	event.stopPropagation();
	event.stopImmediatePropagation();
	if (direction == "left") {
		daerty5.variable.amount_index--;
		if (daerty5.variable.amount_index < 0) {
			daerty5.variable.amount_index = 0;
		}
		SoundManager.playSystemSound(2);
	} else {
		daerty5.variable.amount_index++;
		if (daerty5.variable.amount_index >= daerty5.variable.amounts.length) {
			daerty5.variable.amount_index = daerty5.variable.amounts.length - 1;
		}
		SoundManager.playSystemSound(1);
	}

	daerty5.update_menu();
};

// append the amount selection to the menu
daerty5.append_amount_selection = function (key1, key2) {
	daerty5.append_title("Amount");

	var current_amount = "<font color='#0088ff'>" + daerty5.variable.amounts[daerty5.variable.amount_index] + "</font>";
	daerty5.append_scroll_selector(current_amount, key1, key2, daerty5.scroll_amount);
};

// Left and right scrollers for handling switching amount to modify for the movement cheat
daerty5.scroll_move_amount = function (direction, event) {
	event.stopPropagation();
	event.stopImmediatePropagation();
	if (direction == "left") {
		daerty5.variable.move_amount_index--;
		if (daerty5.variable.move_amount_index < 0) {
			daerty5.variable.move_amount_index = 0;
		}
		SoundManager.playSystemSound(2);
	} else {
		daerty5.variable.move_amount_index++;
		if (daerty5.variable.move_amount_index >= daerty5.variable.move_amounts.length) {
			daerty5.variable.move_amount_index = daerty5.variable.move_amounts.length - 1;
		}
		SoundManager.playSystemSound(1);
	}

	daerty5.update_menu();
};

// append the movement speed amount to the menu
daerty5.append_move_amount_selection = function (key1, key2) {
	daerty5.append_title("Amount");

	var current_amount = "<font color='#0088ff'>" + daerty5.variable.move_amounts[daerty5.variable.move_amount_index] + "</font>";
	daerty5.append_scroll_selector(current_amount, key1, key2, daerty5.scroll_move_amount);
};

// handlers for the exp cheat
daerty5.apply_current_exp = function (direction, event) {
	var amount = daerty5.variable.amounts[daerty5.variable.amount_index];
	if (direction == "left") {
		amount = -amount;
		SoundManager.playSystemSound(2);
	} else {
		SoundManager.playSystemSound(1);
	}
	daerty5.give_exp($gameActors._data[daerty5.variable.cheat_selected_actor], amount);
	daerty5.update_menu();
};

// append the exp cheat to the menu
daerty5.append_exp_cheat = function (key1, key2) {
	var current_exp = "NULL";
	if ($gameActors._data[daerty5.variable.cheat_selected_actor]) {
		current_exp = $gameActors._data[daerty5.variable.cheat_selected_actor].currentExp();
	}
	daerty5.append_title("EXP");
	daerty5.append_scroll_selector(current_exp, key1, key2, daerty5.apply_current_exp);
};

// Left and right scrollers for handling switching between stats for the selected character
daerty5.scroll_stat = function (direction, event) {
	event.stopPropagation();
	event.stopImmediatePropagation();
	if ($gameActors._data[daerty5.variable.cheat_selected_actor] && $gameActors._data[daerty5.variable.cheat_selected_actor]._paramPlus) {
		if (direction == "left") {
			daerty5.variable.stat_selection--;
			if (daerty5.variable.stat_selection < 0) {
				daerty5.variable.stat_selection = $gameActors._data[daerty5.variable.cheat_selected_actor]._paramPlus.length - 1;
			}
		} else {
			daerty5.variable.stat_selection++;
			if (daerty5.variable.stat_selection >= $gameActors._data[daerty5.variable.cheat_selected_actor]._paramPlus.length) {
				daerty5.variable.stat_selection = 0;
			}
		}
	} else {
		daerty5.variable.stat_selection = 0;
	}
	SoundManager.playSystemSound(0);
	daerty5.update_menu();
};

// handlers for the stat cheat
daerty5.apply_current_stat = function (direction, event) {
	var amount = daerty5.variable.amounts[daerty5.variable.amount_index];
	if (direction == "left") {
		amount = -amount;
		SoundManager.playSystemSound(2);
	} else {
		SoundManager.playSystemSound(1);
	}
	daerty5.give_stat($gameActors._data[daerty5.variable.cheat_selected_actor], daerty5.variable.stat_selection, amount);
	daerty5.update_menu();
};

// append the stat selection to the menu
daerty5.append_stat_selection = function (key1, key2, key3, key4) {
	daerty5.append_title("Stat");

	var stat_string = "";

	var stat_string = "";
	if ($gameActors._data[daerty5.variable.cheat_selected_actor] && $gameActors._data[daerty5.variable.cheat_selected_actor]._paramPlus) {
		if (daerty5.variable.stat_selection >= $gameActors._data[daerty5.variable.cheat_selected_actor]._paramPlus.length) {
			daerty5.variable.stat_selection = 0;
		}
		stat_string += $dataSystem.terms.params[daerty5.variable.stat_selection];
	}

	daerty5.append_scroll_selector(stat_string, key1, key2, daerty5.scroll_stat);
	var current_value = "NULL";
	if ($gameActors._data[daerty5.variable.cheat_selected_actor] && $gameActors._data[daerty5.variable.cheat_selected_actor]._paramPlus) {
		current_value = $gameActors._data[daerty5.variable.cheat_selected_actor]._paramPlus[daerty5.variable.stat_selection];
	}
	daerty5.append_scroll_selector(current_value, key3, key4, daerty5.apply_current_stat);
};

