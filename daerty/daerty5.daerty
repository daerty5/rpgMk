// Attach other css for styling
daerty5.style = function () {
	var style = `#daerty5{
		position: absolute;
		width: 280px;
		height: 100px;
		z-index: 1000;
		background-color: #000000;
		color: #ffffff;
		
		opacity: 0.75;
		text-align: center;
		padding: 10px;
	}
	#daerty6 {
		position: absolute;
		width: 30px;
		height: 30px;
		z-index: 1000;

		color: #ffffff;
		opacity: 0.75;
		text-align: center;
		border-radius: 50%; /* Bo tròn góc của thẻ div */
	    transition: background-color 0.3s; /* Hiệu ứng khi thay đổi màu nền */
	}

	#daerty6:hover {
		background-color: blue; /* Chuyển sang màu xanh khi hover */
	}
	#daerty5_text{
		position: absolute;
		width: 300px;
		z-index: 1001;
		background-color: transparent;
		color: #ffffff;
		opacity: 1;
		text-align: center;
		padding: 10px;
	
		border-spacing: 0; 
	}
	
	.scroll_selector_row {
		width: 100%;
		text-align: center;
	}
	
	.scroll_selector_buttons:hover {
		color: #ff0000;
		text-shadow: 0 0 5px #ff0000;
	}
	
	.daerty5_buttons:hover {
		color: #ff0000;
		text-shadow: 0 0 5px #ff0000;
	}
	
	.daerty5_cell {
		border-bottom: 1px solid #6f6f6f;
		max-width: 100px;
		width: 100px;
	
		font-weight: normal;
		font-size: 15px;
		padding-top: 5px;
		padding-bottom: 5px;
	}
	
	.daerty5_cell_title {
		max-width: 100px;
		width: 100px;
		font-weight: bold;
		font-size: 20px;
		padding-top: 8px;
		padding-bottom: 5px;
	}`;
	var styleSheet = document.createElement("style");
	styleSheet.innerText = style;
	document.head.appendChild(styleSheet);
};
daerty5.style();
